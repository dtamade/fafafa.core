{$IFDEF CPU64}
function atomic_fetch_and_64(var aObj: Int64; aArg: Int64): Int64;
var
  LOld, LNew: Int64;
begin
  repeat
    LOld := aObj;
    LNew := LOld and aArg;
  until InterlockedCompareExchange64(aObj, LNew, LOld) = LOld;
  Result := LOld;
end;

function atomic_fetch_and_64(var aObj: UInt64; aArg: UInt64): UInt64;
begin
  Result := UInt64(atomic_fetch_and_64(Int64(aObj), Int64(aArg)));
end;
{$ENDIF}

