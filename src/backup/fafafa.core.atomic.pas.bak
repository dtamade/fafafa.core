end;

function atomic_exchange(var aObj: PtrInt; aDesired: PtrInt): PtrInt;
begin
  {$IF sizeof(PtrInt) = 4}
    Result := PtrInt(InterlockedExchange(PInt32(@aObj)^, PInt32(@aDesired)^));
  {$ELSE}
    Result := PtrInt(InterlockedExchange64(PInt64(@aObj)^, PInt64(@aDesired)^));
  {$ENDIF}
end;

