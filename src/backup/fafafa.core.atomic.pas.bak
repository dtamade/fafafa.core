{$i fafafa.core.settings.inc}

interface

type

  memory_order_t = (
    mo_relaxed,   // 只保证原子性
    mo_consume,   // acquire 语义（读依赖同步）
    mo_acquire,   // acquire 语义
    mo_release,   // store 用
    mo_acq_rel,   // RMW 用，load 部分当 acquire
    mo_seq_cst    // 最强顺序
  );

