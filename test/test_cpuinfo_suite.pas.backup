procedure TCPUInfoTestSuite.TestPlatformSpecific;
var
  StartTime: QWord;
begin
  LogTest('PlatformSpecific', tcBoundary);
  StartTime := GetTickCount64;
  
  try
    {$IFDEF CPUX86_64}
    // x86-64 specific: SSE2 should always be available
    if not GetCPUInfo.X86.HasSSE2 then
      raise Exception.Create('SSE2 not detected on x86-64');
    {$ENDIF}
    
    {$IFDEF CPUARM}
    // ARM specific tests (presence of NEON is common but not guaranteed)
    HasFeature(gfSimd128);
    {$ENDIF}
    
    AddResult('PlatformSpecific', tcBoundary, True, '', GetTickCount64 - StartTime);
  except
    on E: Exception do
      AddResult('PlatformSpecific', tcBoundary, False, E.Message, GetTickCount64 - StartTime);
  end;
end;

