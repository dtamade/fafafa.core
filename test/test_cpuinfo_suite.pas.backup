{ Performance benchmarks }

procedure TCPUInfoTestSuite.BenchmarkDetectionSpeed;
const
  Iterations = 1000;
var
  StartTime, TotalTime: QWord;
  i: Integer;
  Info: TCPUInfo;
begin
  LogTest('DetectionSpeed', tcPerformance);
  
  StartTime := GetTickCount64;
  for i := 1 to Iterations do
    Info := GetCPUInfo;
  TotalTime := GetTickCount64 - StartTime;
  
  if FVerbose then
    WriteLn(Format('  Detection speed: %.2f detections/sec', 
      [Iterations * 1000.0 / TotalTime]));
    
  AddResult('DetectionSpeed', tcPerformance, True, '', TotalTime);
end;

procedure TCPUInfoTestSuite.BenchmarkCachedAccess;
const
  Iterations = 100000;
var
  StartTime, TotalTime: QWord;
  i: Integer;
  FeatureFlag: Boolean;
begin
  LogTest('CachedAccess', tcPerformance);
  
  // Prime the cache
  GetCPUInfo;
  
  StartTime := GetTickCount64;
  for i := 1 to Iterations do
    FeatureFlag := HasFeature(gfSimd128);
  TotalTime := GetTickCount64 - StartTime;
  
  if FVerbose then
    WriteLn(Format('  Cached access: %.2f queries/sec', 
      [Iterations * 1000.0 / TotalTime]));
    
  AddResult('CachedAccess', tcPerformance, True, '', TotalTime);
end;

