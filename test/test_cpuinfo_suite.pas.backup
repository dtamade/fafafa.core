{$mode objfpc}{$H+}
{$modeswitch advancedrecords}

unit test_cpuinfo_suite;

interface

uses
  SysUtils, Classes,
  fafafa.core.simd.cpuinfo,
  // fafafa.core.simd.cpuinfo.lazy,
  fafafa.core.simd.cpuinfo.diagnostic;

type
  { Test categories }
  TTestCategory = (
    tcBasic,          // Basic functionality tests
    tcBoundary,       // Boundary and edge cases
    tcConcurrency,    // Thread safety and concurrency
    tcPerformance,    // Performance benchmarks
    tcIntegration     // Integration tests
  );

  { Test result structure }
  TTestResult = record
    TestName: string;
    Category: TTestCategory;
    Passed: Boolean;
    ErrorMessage: string;
    ExecutionTime: QWord;
  end;

  { Main test suite class }
  TCPUInfoTestSuite = class
  private
    FResults: array of TTestResult;
    FVerbose: Boolean;
    
    procedure AddResult(const AName: string; ACategory: TTestCategory; 
                       APassed: Boolean; const AError: string; ATime: QWord);
    procedure LogTest(const AName: string; ACategory: TTestCategory);
    procedure LogResult(const AResult: TTestResult);
    
  public
    constructor Create(AVerbose: Boolean = False);
    destructor Destroy; override;
    
    { Basic functionality tests }
    procedure TestBasicDetection;
    procedure TestFeatureQueries;
    procedure TestVendorDetection;
    procedure TestCacheInfo;
    
    { Boundary and edge case tests }
    procedure TestInvalidQueries;
    procedure TestUnsupportedFeatures;
    procedure TestPlatformSpecific;
    procedure TestFallbackMechanisms;
    
    { Concurrency tests }
    procedure TestThreadSafeDetection;
    procedure TestConcurrentAccess;
    procedure TestRaceConditions;
    procedure TestDeadlockPrevention;
    
    { Performance benchmarks }
    procedure BenchmarkDetectionSpeed;
    procedure BenchmarkCachedAccess;
    procedure BenchmarkLazyLoading;
    procedure BenchmarkMemoryUsage;
    
    { Integration tests }
    procedure TestWithSIMDOperations;
    procedure TestWithDispatcher;
    procedure TestCrossModuleConsistency;
    procedure TestRealWorldScenarios;
    
    { Test execution }
    procedure RunAllTests;
    procedure RunCategory(ACategory: TTestCategory);
    procedure GenerateReport(const AFileName: string);
    function GetPassRate: Double;
  end;

  { Thread safety test helper }
  TThreadSafetyTester = class(TThread)
  private
    FTestID: Integer;
    FIterations: Integer;
    FErrors: TStringList;
  protected
    procedure Execute; override;
  public
    constructor Create(ATestID, AIterations: Integer);
    destructor Destroy; override;
    property Errors: TStringList read FErrors;
  end;

  { Performance measurement helper }
  TPerformanceTester = class
  private
    FStartTime: QWord;
    FEndTime: QWord;
    FSamples: array of QWord;
    
  public
    procedure StartMeasurement;
    procedure StopMeasurement;
    procedure AddSample(ATime: QWord);
    function GetAverage: Double;
    function GetMedian: QWord;
    function GetStdDev: Double;
    procedure Reset;
  end;

implementation

uses
  {$IFDEF WINDOWS}Windows,{$ENDIF}
  {$IFDEF UNIX}Unix, BaseUnix,{$ENDIF}
  fafafa.core.simd.cpuinfo.base,
  fafafa.core.simd.sync;

{ Utility functions }
function GetTickCount64: QWord;
begin
  {$IFDEF WINDOWS}
  Result := Windows.GetTickCount64;
  {$ELSE}
  Result := GetTickCount;
  {$ENDIF}
end;

{ TCPUInfoTestSuite }

constructor TCPUInfoTestSuite.Create(AVerbose: Boolean);
begin
  inherited Create;
  FVerbose := AVerbose;
  SetLength(FResults, 0);
end;

destructor TCPUInfoTestSuite.Destroy;
begin
  SetLength(FResults, 0);
  inherited;
end;

procedure TCPUInfoTestSuite.AddResult(const AName: string; ACategory: TTestCategory;
  APassed: Boolean; const AError: string; ATime: QWord);
var
  Idx: Integer;
begin
  Idx := Length(FResults);
  SetLength(FResults, Idx + 1);
  FResults[Idx].TestName := AName;
  FResults[Idx].Category := ACategory;
  FResults[Idx].Passed := APassed;
  FResults[Idx].ErrorMessage := AError;
  FResults[Idx].ExecutionTime := ATime;
  
  if FVerbose then
    LogResult(FResults[Idx]);
end;

procedure TCPUInfoTestSuite.LogTest(const AName: string; ACategory: TTestCategory);
const
  CategoryNames: array[TTestCategory] of string = (
    'Basic', 'Boundary', 'Concurrency', 'Performance', 'Integration'
  );
begin
  if FVerbose then
    WriteLn(Format('[%s] Running: %s', [CategoryNames[ACategory], AName]));
end;

procedure TCPUInfoTestSuite.LogResult(const AResult: TTestResult);
const
  CategoryNames: array[TTestCategory] of string = (
    'Basic', 'Boundary', 'Concurrency', 'Performance', 'Integration'
  );
begin
  if AResult.Passed then
    WriteLn(Format('[%s] PASS: %s (%d ms)', 
      [CategoryNames[AResult.Category], AResult.TestName, AResult.ExecutionTime]))
  else
    WriteLn(Format('[%s] FAIL: %s - %s', 
      [CategoryNames[AResult.Category], AResult.TestName, AResult.ErrorMessage]));
end;

{ Basic functionality tests }

procedure TCPUInfoTestSuite.TestBasicDetection;
var
  StartTime: QWord;
  Info: TCPUInfo;
begin
  LogTest('BasicDetection', tcBasic);
  StartTime := GetTickCount64;
  
  try
    Info := GetCPUInfo;
    
    // Verify basic fields are populated
    if (Info.Vendor = '') or (Info.Model = '') then
      raise Exception.Create('Basic CPU info fields not populated');
      
    AddResult('BasicDetection', tcBasic, True, '', GetTickCount64 - StartTime);
  except
    on E: Exception do
      AddResult('BasicDetection', tcBasic, False, E.Message, GetTickCount64 - StartTime);
  end;
end;

procedure TCPUInfoTestSuite.TestFeatureQueries;
var
  StartTime: QWord;
begin
  LogTest('FeatureQueries', tcBasic);
  StartTime := GetTickCount64;
  
  try
    // Test various feature queries (generic)
    HasFeature(gfSimd128);
    HasFeature(gfSimd256);
    
    // Test that queries don't crash
    AddResult('FeatureQueries', tcBasic, True, '', GetTickCount64 - StartTime);
  except
    on E: Exception do
      AddResult('FeatureQueries', tcBasic, False, E.Message, GetTickCount64 - StartTime);
  end;
end;

procedure TCPUInfoTestSuite.TestVendorDetection;
var
  StartTime: QWord;
  Info: TCPUInfo;
begin
  LogTest('VendorDetection', tcBasic);
  StartTime := GetTickCount64;
  
  try
    Info := GetCPUInfo;
    
    // Check vendor is one of known values
    if not (Info.Vendor in ['GenuineIntel', 'AuthenticAMD', 'Unknown']) then
      raise Exception.Create('Unknown vendor: ' + Info.Vendor);
      
    AddResult('VendorDetection', tcBasic, True, '', GetTickCount64 - StartTime);
  except
    on E: Exception do
      AddResult('VendorDetection', tcBasic, False, E.Message, GetTickCount64 - StartTime);
  end;
end;

procedure TCPUInfoTestSuite.TestCacheInfo;
var
  StartTime: QWord;
  Info: TCPUInfo;
begin
  LogTest('CacheInfo', tcBasic);
  StartTime := GetTickCount64;
  
  try
    Info := GetCPUInfo;
    
    // Verify cache sizes are reasonable (if detected)
    if Info.Cache.L1DataKB > 0 then
      if (Info.Cache.L1DataKB < 8) or (Info.Cache.L1DataKB > 256) then
        raise Exception.Create('Unreasonable L1 cache size');
        
    AddResult('CacheInfo', tcBasic, True, '', GetTickCount64 - StartTime);
  except
    on E: Exception do
      AddResult('CacheInfo', tcBasic, False, E.Message, GetTickCount64 - StartTime);
  end;
end;

