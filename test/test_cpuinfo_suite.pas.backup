{ Test execution }

procedure TCPUInfoTestSuite.RunAllTests;
begin
  WriteLn('Running CPU Info Test Suite...');
  WriteLn('==============================');
  
  // Basic tests
  TestBasicDetection;
  TestFeatureQueries;
  TestVendorDetection;
  TestCacheInfo;
  
  // Boundary tests
  TestInvalidQueries;
  TestUnsupportedFeatures;
  TestPlatformSpecific;
  TestFallbackMechanisms;
  
  // Concurrency tests
  TestThreadSafeDetection;
  TestConcurrentAccess;
  TestRaceConditions;
  TestDeadlockPrevention;
  
  // Performance benchmarks
  BenchmarkDetectionSpeed;
  BenchmarkCachedAccess;
  BenchmarkLazyLoading;
  BenchmarkMemoryUsage;
  
  // Integration tests
  TestWithSIMDOperations;
  TestWithDispatcher;
  TestCrossModuleConsistency;
  TestRealWorldScenarios;
  
  WriteLn('==============================');
  WriteLn(Format('Pass rate: %.1f%%', [GetPassRate]));
end;

procedure TCPUInfoTestSuite.RunCategory(ACategory: TTestCategory);
begin
  case ACategory of
    tcBasic:
      begin
        TestBasicDetection;
        TestFeatureQueries;
        TestVendorDetection;
        TestCacheInfo;
      end;
    tcBoundary:
      begin
        TestInvalidQueries;
        TestUnsupportedFeatures;
        TestPlatformSpecific;
        TestFallbackMechanisms;
      end;
    tcConcurrency:
      begin
        TestThreadSafeDetection;
        TestConcurrentAccess;
        TestRaceConditions;
        TestDeadlockPrevention;
      end;
    tcPerformance:
      begin
        BenchmarkDetectionSpeed;
        BenchmarkCachedAccess;
        BenchmarkLazyLoading;
        BenchmarkMemoryUsage;
      end;
    tcIntegration:
      begin
        TestWithSIMDOperations;
        TestWithDispatcher;
        TestCrossModuleConsistency;
        TestRealWorldScenarios;
      end;
  end;
end;

procedure TCPUInfoTestSuite.GenerateReport(const AFileName: string);
const
  CategoryNames: array[TTestCategory] of string = (
    'Basic', 'Boundary', 'Concurrency', 'Performance', 'Integration'
  );
var
  F: TextFile;
  i: Integer;
  PassCount, FailCount: Integer;
begin
  AssignFile(F, AFileName);
  Rewrite(F);
  try
    WriteLn(F, 'CPU Info Test Suite Report');
    WriteLn(F, '==========================');
    WriteLn(F);
    
    PassCount := 0;
    FailCount := 0;
    
    for i := 0 to High(FResults) do
    begin
      WriteLn(F, Format('[%s] %s: %s', 
        [CategoryNames[FResults[i].Category],
         FResults[i].TestName,
         IfThen(FResults[i].Passed, 'PASS', 'FAIL')]));
         
      if not FResults[i].Passed then
        WriteLn(F, '  Error: ' + FResults[i].ErrorMessage);
        
      if FResults[i].Passed then
        Inc(PassCount)
      else
        Inc(FailCount);
    end;
    
    WriteLn(F);
    WriteLn(F, Format('Total: %d tests, %d passed, %d failed', 
      [PassCount + FailCount, PassCount, FailCount]));
    WriteLn(F, Format('Pass rate: %.1f%%', [GetPassRate]));
  finally
    CloseFile(F);
  end;
end;

function TCPUInfoTestSuite.GetPassRate: Double;
var
  i, PassCount: Integer;
begin
  if Length(FResults) = 0 then
    Exit(0.0);
    
  PassCount := 0;
  for i := 0 to High(FResults) do
    if FResults[i].Passed then
      Inc(PassCount);
      
  Result := (PassCount * 100.0) / Length(FResults);
end;

{ TThreadSafetyTester }

constructor TThreadSafetyTester.Create(ATestID, AIterations: Integer);
begin
  inherited Create(True);
  FTestID := ATestID;
  FIterations := AIterations;
  FErrors := TStringList.Create;
  FreeOnTerminate := False;
end;

destructor TThreadSafetyTester.Destroy;
begin
  FErrors.Free;
  inherited;
end;

procedure TThreadSafetyTester.Execute;
var
  i: Integer;
  Info: TCPUInfo;
  FeatureFlag: Boolean;
begin
  try
    for i := 1 to FIterations do
    begin
      // Test various operations
      Info := GetCPUInfo;
      FeatureFlag := HasFeature(gfSimd128);
      FeatureFlag := HasFeature(gfSimd256);
      
      // Add random delays to increase chance of race conditions
      Sleep(Random(5));
      
      if Terminated then
        Break;
    end;
  except
    on E: Exception do
      FErrors.Add(Format('Thread %d: %s', [FTestID, E.Message]));
  end;
end;

{ TPerformanceTester }

procedure TPerformanceTester.StartMeasurement;
begin
  FStartTime := GetTickCount64;
end;

procedure TPerformanceTester.StopMeasurement;
begin
  FEndTime := GetTickCount64;
  AddSample(FEndTime - FStartTime);
end;

procedure TPerformanceTester.AddSample(ATime: QWord);
var
  Len: Integer;
begin
  Len := Length(FSamples);
  SetLength(FSamples, Len + 1);
  FSamples[Len] := ATime;
end;

function TPerformanceTester.GetAverage: Double;
var
  i: Integer;
  Sum: QWord;
begin
  if Length(FSamples) = 0 then
    Exit(0);
    
  Sum := 0;
  for i := 0 to High(FSamples) do
    Sum := Sum + FSamples[i];
    
  Result := Sum / Length(FSamples);
end;

function TPerformanceTester.GetMedian: QWord;
var
  Sorted: array of QWord;
  i, j: Integer;
  Temp: QWord;
begin
  if Length(FSamples) = 0 then
    Exit(0);
    
  // Copy and sort samples
  SetLength(Sorted, Length(FSamples));
  for i := 0 to High(FSamples) do
    Sorted[i] := FSamples[i];
    
  // Simple bubble sort (fine for small datasets)
  for i := 0 to High(Sorted) - 1 do
    for j := i + 1 to High(Sorted) do
      if Sorted[i] > Sorted[j] then
      begin
        Temp := Sorted[i];
        Sorted[i] := Sorted[j];
        Sorted[j] := Temp;
      end;
      
  Result := Sorted[Length(Sorted) div 2];
end;

function TPerformanceTester.GetStdDev: Double;
var
  i: Integer;
  Avg, Sum: Double;
begin
  if Length(FSamples) <= 1 then
    Exit(0);
    
  Avg := GetAverage;
  Sum := 0;
  
  for i := 0 to High(FSamples) do
    Sum := Sum + Sqr(FSamples[i] - Avg);
    
  Result := Sqrt(Sum / (Length(FSamples) - 1));
end;

procedure TPerformanceTester.Reset;
begin
  SetLength(FSamples, 0);
  FStartTime := 0;
  FEndTime := 0;
end;

function IfThen(ACondition: Boolean; const ATrue, AFalse: string): string;
begin
  if ACondition then
    Result := ATrue
  else
    Result := AFalse;
end;

end.
