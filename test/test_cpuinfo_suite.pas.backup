{ Concurrency tests }

procedure TCPUInfoTestSuite.TestThreadSafeDetection;
const
  ThreadCount = 10;
  IterationsPerThread = 100;
var
  StartTime: QWord;
  Threads: array[0..ThreadCount-1] of TThreadSafetyTester;
  i: Integer;
  HasErrors: Boolean;
begin
  LogTest('ThreadSafeDetection', tcConcurrency);
  StartTime := GetTickCount64;
  
  try
    // Create and start threads
    for i := 0 to ThreadCount - 1 do
    begin
      Threads[i] := TThreadSafetyTester.Create(i, IterationsPerThread);
      Threads[i].Start;
    end;
    
    // Wait for all threads to complete
    HasErrors := False;
    for i := 0 to ThreadCount - 1 do
    begin
      Threads[i].WaitFor;
      if Threads[i].Errors.Count > 0 then
        HasErrors := True;
      Threads[i].Free;
    end;
    
    if HasErrors then
      raise Exception.Create('Thread safety violations detected');
      
    AddResult('ThreadSafeDetection', tcConcurrency, True, '', GetTickCount64 - StartTime);
  except
    on E: Exception do
      AddResult('ThreadSafeDetection', tcConcurrency, False, E.Message, GetTickCount64 - StartTime);
  end;
end;

