      </Unit>
    </Units>
  </ProjectOptions>
  <CompilerOptions>
    <Version Value="11"/>
    <PathDelim Value="\"/>
    <Target>
      <Filename Value="bin\fafafa.core.sync.semaphore.benchmark"/>
    </Target>
    <SearchPaths>
      <IncludeFiles Value="..\..\src"/>
