        <ShowWarn Value="False"/>
        <ShowNotes Value="False"/>
        <ShowHints Value="False"/>
        <ShowGenInfo Value="False"/>
      </Verbosity>
      <CustomOptions Value="-O3 -CX -XX -Xs"/>
