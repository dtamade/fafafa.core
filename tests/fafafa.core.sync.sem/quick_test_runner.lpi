<?xml version="1.0" encoding="UTF-8"?>
<CONFIG>
  <ProjectOptions>
    <Version Value="12"/>
    <PathDelim Value="\"/>
    <General>
      <Title Value="Quick Test Runner"/>
      <ResourceType Value="res"/>
      <UseAppBundle Value="False"/>
    </General>
    <BuildModes>
      <Item Name="Debug" Default="True">
        <CompilerOptions>
          <Version Value="11"/>
          <Target>
            <Filename Value="bin/quick_test_runner"/>
          </Target>
          <SearchPaths>
            <OtherUnitFiles Value="..\..\src"/>
            <IncludeFiles Value="../../src"/>
            <UnitOutputDirectory Value="lib/$(TargetCPU)-$(TargetOS)"/>
          </SearchPaths>
          <Linking>
            <Debugging>
              <UseHeaptrc Value="True"/>
            </Debugging>
          </Linking>
        </CompilerOptions>
      </Item>
    </BuildModes>
    <RequiredPackages>
      <Item>
        <PackageName Value="FCL"/>
      </Item>
      <Item>
        <PackageName Value="fpcunittestrunner"/>
      </Item>
    </RequiredPackages>
    <Units>
      <Unit>
        <Filename Value="bin/quick_test_runner"/>
        <IsPartOfProject Value="True"/>
      </Unit>
      <Unit>
        <Filename Value="bin/quick_test_runner"/>
        <IsPartOfProject Value="True"/>
      </Unit>
    </Units>
  </ProjectOptions>
  <CompilerOptions>
    <Version Value="11"/>
    <Target>
      <Filename Value="bin/quick_test_runner"/>
    </Target>
    <SearchPaths>
      <OtherUnitFiles Value="..\..\src"/>
      <IncludeFiles Value="../../src"/>
      <UnitOutputDirectory Value="lib/$(TargetCPU)-$(TargetOS)"/>
    </SearchPaths>
    <Linking>
      <Debugging>
        <UseHeaptrc Value="True"/>
      </Debugging>
    </Linking>
  </CompilerOptions>
</CONFIG>
