<?xml version="1.0" encoding="UTF-8"?>
<CONFIG>
  <ProjectOptions>
    <Version Value="12"/>
    <PathDelim Value="\"/>
    <General>
      <Title Value="Simple Sem Test"/>
      <ResourceType Value="res"/>
      <UseAppBundle Value="False"/>
    </General>
    <BuildModes>
      <Item Name="Debug" Default="True">
        <CompilerOptions>
          <Version Value="11"/>
          <Target>
            <Filename Value="bin\simple_test.exe"/>
          </Target>
          <SearchPaths>
            <OtherUnitFiles Value="..\..\src"/>
            <IncludeFiles Value="../../src"/>
            <UnitOutputDirectory Value="lib\$(TargetCPU)-$(TargetOS)"/>
          </SearchPaths>
          <Linking>
            <Debugging>
              <UseHeaptrc Value="True"/>
            </Debugging>
          </Linking>
          <Other>
            <CompilerMessages>
              <IgnoredMessages idx5024="True"/>
            </CompilerMessages>
          </Other>
        </CompilerOptions>
      </Item>
    </BuildModes>
    <Units>
      <Unit>
        <Filename Value="simple_test.lpr"/>
        <IsPartOfProject Value="True"/>
      </Unit>
    </Units>
  </ProjectOptions>
  <CompilerOptions>
    <Version Value="11"/>
    <Target>
      <Filename Value="bin\simple_test.exe"/>
    </Target>
    <SearchPaths>
      <OtherUnitFiles Value="..\..\src"/>
      <IncludeFiles Value="../../src"/>
      <UnitOutputDirectory Value="lib\$(TargetCPU)-$(TargetOS)"/>
    </SearchPaths>
    <Linking>
      <Debugging>
        <UseHeaptrc Value="True"/>
      </Debugging>
    </Linking>
    <Other>
      <CompilerMessages>
        <IgnoredMessages idx5024="True"/>
      </CompilerMessages>
    </Other>
  </CompilerOptions>
</CONFIG>
