<?xml version="1.0" encoding="UTF-8"?>
<CONFIG>
  <ProjectOptions>
    <Version Value="12"/>
    <PathDelim Value="\"/>
    <General>
      <Title Value="Enhanced Semaphore Test"/>
      <ResourceType Value="res"/>
      <UseAppBundle Value="False"/>
    </General>
    <BuildModes>
      <Item Name="Debug" Default="True">
        <CompilerOptions>
          <Version Value="11"/>
          <Target>
            <Filename Value="bin\fafafa.core.sync.sem.enhanced.test.exe"/>
          </Target>
          <SearchPaths>
            <OtherUnitFiles Value="..\..\src"/>
            <IncludeFiles Value="../../src"/>
            <UnitOutputDirectory Value="lib\$(TargetCPU)-$(TargetOS)"/>
          </SearchPaths>
          <Parsing>
            <SyntaxOptions>
              <SyntaxMode Value="ObjFPC"/>
              <CStyleOperator Value="False"/>
              <AllowLabel Value="False"/>
              <CPPInline Value="False"/>
            </SyntaxOptions>
          </Parsing>
          <CodeGeneration>
            <SmartLinkUnit Value="True"/>
            <Optimizations>
              <OptimizationLevel Value="1"/>
            </Optimizations>
          </CodeGeneration>
          <Linking>
            <Debugging>
              <DebugInfoType Value="dsDwarf3"/>
              <UseHeaptrc Value="True"/>
              <TrashVariables Value="True"/>
              <UseExternalDbgSyms Value="True"/>
            </Debugging>
            <LinkSmart Value="True"/>
          </Linking>
          <Other>
            <Verbosity>
              <ShowWarn Value="True"/>
              <ShowNotes Value="True"/>
              <ShowHints Value="True"/>
              <ShowGenInfo Value="True"/>
            </Verbosity>
          </Other>
        </CompilerOptions>
      </Item>
    </BuildModes>
    <Units>
      <Unit>
        <Filename Value="fafafa.core.sync.sem.enhanced.test.lpr"/>
        <IsPartOfProject Value="True"/>
      </Unit>
      <Unit>
        <Filename Value="fafafa.core.sync.sem.enhanced.testcase.pas"/>
        <IsPartOfProject Value="True"/>
      </Unit>
    </Units>
  </ProjectOptions>
  <CompilerOptions>
    <Version Value="11"/>
    <Target>
      <Filename Value="bin\fafafa.core.sync.sem.enhanced.test.exe"/>
    </Target>
    <SearchPaths>
      <OtherUnitFiles Value="..\..\src"/>
      <IncludeFiles Value="../../src"/>
      <UnitOutputDirectory Value="lib\$(TargetCPU)-$(TargetOS)"/>
    </SearchPaths>
    <Parsing>
      <SyntaxOptions>
        <SyntaxMode Value="ObjFPC"/>
        <CStyleOperator Value="False"/>
        <AllowLabel Value="False"/>
        <CPPInline Value="False"/>
      </SyntaxOptions>
    </Parsing>
    <CodeGeneration>
      <SmartLinkUnit Value="True"/>
      <Optimizations>
        <OptimizationLevel Value="1"/>
      </Optimizations>
    </CodeGeneration>
    <Linking>
      <Debugging>
        <DebugInfoType Value="dsDwarf3"/>
        <UseHeaptrc Value="True"/>
        <TrashVariables Value="True"/>
        <UseExternalDbgSyms Value="True"/>
      </Debugging>
      <LinkSmart Value="True"/>
    </Linking>
    <Other>
      <Verbosity>
        <ShowWarn Value="True"/>
        <ShowNotes Value="True"/>
        <ShowHints Value="True"/>
        <ShowGenInfo Value="True"/>
      </Verbosity>
    </Other>
  </CompilerOptions>
</CONFIG>
