procedure TTestCase_VecDeque.Test_Replace_StartIndex;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LStartIndex: SizeUInt;
begin
  { 测试 Replace_StartIndex - 从指定索引开始替换元素 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 准备测试数据 }
    LVecDeque.PushBack(1);
    LVecDeque.PushBack(2);
    LVecDeque.PushBack(1);
    LVecDeque.PushBack(3);
    LVecDeque.PushBack(1);
    LVecDeque.PushBack(2);
    LVecDeque.PushBack(1);

    LStartIndex := 2;

    { 从索引2开始替换所有的1为99 }
    LVecDeque.Replace(1, 99, LStartIndex);

    { 验证结果 }
    AssertEquals('元素数量应该保持不变', 7, LVecDeque.Count);
    { 前面的元素应该保持不变 }
    AssertEquals('索引0的元素应该保持不变', 1, LVecDeque.Get(0));
    AssertEquals('索引1的元素应该保持不变', 2, LVecDeque.Get(1));
    { 从起始索引开始的匹配元素应该被替换 }
    AssertEquals('索引2的元素应该被替换', 99, LVecDeque.Get(2));
    AssertEquals('索引3的元素应该保持不变', 3, LVecDeque.Get(3));
    AssertEquals('索引4的元素应该被替换', 99, LVecDeque.Get(4));
    AssertEquals('索引5的元素应该保持不变', 2, LVecDeque.Get(5));
    AssertEquals('索引6的元素应该被替换', 99, LVecDeque.Get(6));
  finally
    LVecDeque.Free;
  end;
end;

