procedure TTestCase_VecDeque.Test_Create_Pointer_Count;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LArray: array[0..4] of Integer;
  LPointer: Pointer;
  LCount: SizeUInt;
begin
  { 测试 Create_Pointer_Count - 使用指针和数量的构造函数 }
  for var i := 0 to High(LArray) do
    LArray[i] := (i + 1) * 13;

  LPointer := @LArray[0];
  LCount := Length(LArray);

  LVecDeque := specialize TVecDeque<Integer>.Create(LPointer, LCount);
  try
    AssertNotNull('使用指针和数量创建的VecDeque应该有效', LVecDeque);
    AssertEquals('元素数量应该等于指定数量', LCount, LVecDeque.Count);

    { 验证数据被正确复制 }
    for var i := 0 to High(LArray) do
      AssertEquals('指针数据应该被正确复制', LArray[i], LVecDeque.Get(i));

    { 验证独立性 }
    LArray[0] := 999;
    AssertEquals('修改原数据不应该影响VecDeque', 13, LVecDeque.Get(0));
  finally
    LVecDeque.Free;
  end;
end;

