procedure TTestCase_VecDeque.Test_BinarySearchInsert_StartIndex_Count_Element_RefFunc;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LInsertIndex, LStartIndex, LCount: SizeUInt;
begin
  { 测试 BinarySearchInsert_StartIndex_Count_Element_RefFunc - 在指定范围内使用引用函数二分查找插入位置 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 准备测试数据 }
    LVecDeque.PushBack(555);  { 范围外 }
    LVecDeque.PushBack(444);  { 范围外 }
    LVecDeque.PushBack(6);    { 排序范围开始 }
    LVecDeque.PushBack(12);
    LVecDeque.PushBack(18);
    LVecDeque.PushBack(24);   { 排序范围结束 }
    LVecDeque.PushBack(333);  { 范围外 }

    LStartIndex := 2;
    LCount := 4;

    { 在指定范围内使用引用函数查找插入位置 }
    LInsertIndex := LVecDeque.BinarySearchInsert(15, LStartIndex, LCount, @CompareTestRefFunc);
    AssertEquals('应该在指定范围内的正确位置插入', SizeUInt(4), LInsertIndex);

    { 查找插入位置 - 在范围末尾 }
    LInsertIndex := LVecDeque.BinarySearchInsert(30, LStartIndex, LCount, @CompareTestRefFunc);
    AssertEquals('应该在范围末尾插入', SizeUInt(6), LInsertIndex);
  finally
    LVecDeque.Free;
  end;
end;

{ 完成剩余的IsSorted系列测试实现 }

procedure TTestCase_VecDeque.Test_IsSorted_StartIndex_Method;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LResult: Boolean;
  LStartIndex: SizeUInt;
begin
  { 测试 IsSorted_StartIndex_Method - 从指定索引开始使用方法指针检查是否已排序 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 准备测试数据 }
    LVecDeque.PushBack(15);  { 未排序部分 }
    LVecDeque.PushBack(5);   { 未排序部分 }
    LVecDeque.PushBack(2);   { 排序部分开始 }
    LVecDeque.PushBack(4);
    LVecDeque.PushBack(6);
    LVecDeque.PushBack(8);
    LVecDeque.PushBack(10);

    LStartIndex := 2;

    { 从索引2开始使用方法指针检查排序状态 }
    LResult := LVecDeque.IsSorted(LStartIndex, @CompareTestMethod, @Self);
    AssertTrue('从索引2开始应该是已排序的', LResult);

    { 从索引0开始检查 }
    LResult := LVecDeque.IsSorted(0, @CompareTestMethod, @Self);
    AssertFalse('从索引0开始应该是未排序的', LResult);
  finally
    LVecDeque.Free;
  end;
end;

