{ 完成剩余的Shuffle系列测试实现 }

procedure TTestCase_VecDeque.Test_Shuffle_Func;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LOriginalElements: array[0..5] of Integer;
  LShuffled: Boolean;
begin
  { 测试 Shuffle_Func - 使用函数指针随机打乱所有元素 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 准备测试数据 }
    for var i := 0 to High(LOriginalElements) do
    begin
      LOriginalElements[i] := (i + 1) * 10;
      LVecDeque.PushBack(LOriginalElements[i]);
    end;

    { 执行使用函数指针的打乱 }
    LVecDeque.Shuffle(@RandomTestFunc, @Self);

    { 验证结果 }
    AssertEquals('元素数量应该保持不变', Length(LOriginalElements), LVecDeque.Count);

    { 验证所有原始元素仍然存在 }
    for var i := 0 to High(LOriginalElements) do
    begin
      var LFound := False;
      for var j := 0 to LVecDeque.Count - 1 do
      begin
        if LVecDeque.Get(j) = LOriginalElements[i] then
        begin
          LFound := True;
          Break;
        end;
      end;
      AssertTrue('原始元素在打乱后应该仍然存在', LFound);
    end;

    { 检查是否真的被打乱了（至少有一个元素位置改变） }
    LShuffled := False;
    for var i := 0 to LVecDeque.Count - 1 do
    begin
      if LVecDeque.Get(i) <> LOriginalElements[i] then
      begin
        LShuffled := True;
        Break;
      end;
    end;
    { 注意：理论上有很小概率打乱后顺序不变，但对于6个元素来说概率很低 }
    AssertTrue('元素很可能被打乱了', LShuffled);
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_Shuffle_Method;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LOriginalElements: array[0..4] of Integer;
begin
  { 测试 Shuffle_Method - 使用方法指针随机打乱所有元素 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 准备测试数据 }
    for var i := 0 to High(LOriginalElements) do
    begin
      LOriginalElements[i] := (i + 1) * 7;
      LVecDeque.PushBack(LOriginalElements[i]);
    end;

    { 执行使用方法指针的打乱 }
    LVecDeque.Shuffle(@RandomTestMethod, @Self);

    { 验证结果 }
    AssertEquals('元素数量应该保持不变', Length(LOriginalElements), LVecDeque.Count);

    { 验证所有原始元素仍然存在 }
    for var i := 0 to High(LOriginalElements) do
    begin
      var LFound := False;
      for var j := 0 to LVecDeque.Count - 1 do
      begin
        if LVecDeque.Get(j) = LOriginalElements[i] then
        begin
          LFound := True;
          Break;
        end;
      end;
      AssertTrue('原始元素在打乱后应该仍然存在', LFound);
    end;
  finally
    LVecDeque.Free;
  end;
end;

