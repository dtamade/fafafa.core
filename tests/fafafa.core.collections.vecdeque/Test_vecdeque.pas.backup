    { 验证结果 }
    AssertEquals('Count should remain same', 5, LVecDeque.Count);
    for var i := 0 to LVecDeque.Count - 1 do
      AssertEquals('All elements should be zero', 0, LVecDeque.Get(i));
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_Zero_Index;
var
