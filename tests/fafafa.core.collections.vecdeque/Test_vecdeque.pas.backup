{ 完成剩余的Replace系列测试实现 }

procedure TTestCase_VecDeque.Test_Replace_OldValue_NewValue_Method;
var
  LVecDeque: specialize TVecDeque<Integer>;
begin
  { 测试 Replace_OldValue_NewValue_Method - 使用方法指针替换元素 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 准备测试数据 }
    LVecDeque.PushBack(10);
    LVecDeque.PushBack(20);
    LVecDeque.PushBack(10);
    LVecDeque.PushBack(30);
    LVecDeque.PushBack(10);
    LVecDeque.PushBack(20);

    { 使用方法指针替换所有的10为100 }
    LVecDeque.Replace(10, 100, @EqualsTestMethod, @Self);

    { 验证结果 }
    AssertEquals('元素数量应该保持不变', 6, LVecDeque.Count);
    AssertEquals('第一个元素应该被替换', 100, LVecDeque.Get(0));
    AssertEquals('第二个元素应该保持不变', 20, LVecDeque.Get(1));
    AssertEquals('第三个元素应该被替换', 100, LVecDeque.Get(2));
    AssertEquals('第四个元素应该保持不变', 30, LVecDeque.Get(3));
    AssertEquals('第五个元素应该被替换', 100, LVecDeque.Get(4));
    AssertEquals('第六个元素应该保持不变', 20, LVecDeque.Get(5));
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_Replace_OldValue_NewValue_RefFunc;
var
  LVecDeque: specialize TVecDeque<Integer>;
