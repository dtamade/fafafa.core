{ IsSorted 范围变体测试实现 }

procedure TTestCase_VecDeque.Test_IsSorted_StartIndex;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LResult: Boolean;
  LStartIndex: SizeUInt;
begin
  { 测试 IsSorted_StartIndex - 从指定索引开始检查是否已排序 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 准备部分排序的测试数据 }
    LVecDeque.PushBack(5);   { 未排序部分 }
    LVecDeque.PushBack(3);   { 未排序部分 }
    LVecDeque.PushBack(1);   { 排序部分开始 }
    LVecDeque.PushBack(2);
    LVecDeque.PushBack(4);
    LVecDeque.PushBack(6);

    LStartIndex := 2;

    { 从索引2开始检查排序状态 }
    LResult := LVecDeque.IsSorted(LStartIndex);
    AssertTrue('从索引2开始应该是已排序的', LResult);

    { 从索引0开始检查（整个数组未排序） }
    LResult := LVecDeque.IsSorted(0);
    AssertFalse('从索引0开始应该是未排序的', LResult);

    { 从最后一个索引开始检查 }
    LResult := LVecDeque.IsSorted(5);
    AssertTrue('单个元素应该被认为是已排序的', LResult);
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_IsSorted_StartIndex_Func;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LResult: Boolean;
  LStartIndex: SizeUInt;
begin
  { 测试 IsSorted_StartIndex_Func - 从指定索引开始使用函数指针检查是否已排序 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 准备测试数据 }
    LVecDeque.PushBack(10);  { 未排序部分 }
    LVecDeque.PushBack(8);   { 未排序部分 }
    LVecDeque.PushBack(2);   { 排序部分开始 }
    LVecDeque.PushBack(4);
    LVecDeque.PushBack(6);
    LVecDeque.PushBack(8);

    LStartIndex := 2;

    { 从索引2开始使用函数指针检查排序状态 }
    LResult := LVecDeque.IsSorted(LStartIndex, @CompareTestFunc, @Self);
    AssertTrue('从索引2开始应该是已排序的', LResult);

    { 从索引0开始检查 }
    LResult := LVecDeque.IsSorted(0, @CompareTestFunc, @Self);
    AssertFalse('从索引0开始应该是未排序的', LResult);
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_IsSorted_StartIndex_Count;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LResult: Boolean;
  LStartIndex, LCount: SizeUInt;
begin
  { 测试 IsSorted_StartIndex_Count - 在指定范围内检查是否已排序 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 准备测试数据 }
    LVecDeque.PushBack(9);   { 范围外 }
    LVecDeque.PushBack(1);   { 排序范围开始 }
    LVecDeque.PushBack(3);
    LVecDeque.PushBack(5);
    LVecDeque.PushBack(7);   { 排序范围结束 }
    LVecDeque.PushBack(2);   { 范围外 }

    LStartIndex := 1;
    LCount := 4;

    { 在指定范围内检查排序状态 }
    LResult := LVecDeque.IsSorted(LStartIndex, LCount);
    AssertTrue('指定范围内应该是已排序的', LResult);

    { 扩大范围包含未排序部分 }
    LResult := LVecDeque.IsSorted(0, 6);
    AssertFalse('包含未排序部分的范围应该是未排序的', LResult);

    { 测试边界情况：范围为1 }
    LResult := LVecDeque.IsSorted(LStartIndex, 1);
    AssertTrue('单个元素范围应该被认为是已排序的', LResult);
  finally
    LVecDeque.Free;
  end;
end;

{ SortUnChecked 系列测试实现 }

procedure TTestCase_VecDeque.Test_SortUnChecked;
var
  LVecDeque: specialize TVecDeque<Integer>;
begin
  { 测试 SortUnChecked - 不检查边界的默认排序 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 准备无序测试数据 }
    LVecDeque.PushBack(8);
    LVecDeque.PushBack(3);
    LVecDeque.PushBack(9);
    LVecDeque.PushBack(1);
    LVecDeque.PushBack(6);
    LVecDeque.PushBack(4);

    { 执行不检查边界的排序 }
    LVecDeque.SortUnChecked;

    { 验证结果 }
    AssertEquals('元素数量应该保持不变', 6, LVecDeque.Count);
    AssertEquals('第一个元素应该是最小值', 1, LVecDeque.Get(0));
    AssertEquals('第二个元素应该正确', 3, LVecDeque.Get(1));
    AssertEquals('第三个元素应该正确', 4, LVecDeque.Get(2));
    AssertEquals('第四个元素应该正确', 6, LVecDeque.Get(3));
    AssertEquals('第五个元素应该正确', 8, LVecDeque.Get(4));
    AssertEquals('最后一个元素应该是最大值', 9, LVecDeque.Get(5));
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_SortUnChecked_Func;
var
  LVecDeque: specialize TVecDeque<Integer>;
begin
  { 测试 SortUnChecked_Func - 不检查边界使用函数指针排序 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 准备测试数据 }
    LVecDeque.PushBack(15);
    LVecDeque.PushBack(5);
    LVecDeque.PushBack(25);
    LVecDeque.PushBack(10);
    LVecDeque.PushBack(20);

    { 使用函数指针进行不检查边界的排序 }
    LVecDeque.SortUnChecked(@CompareTestFunc, @Self);

    { 验证结果 }
    AssertEquals('元素数量应该保持不变', 5, LVecDeque.Count);
    { 验证是否按升序排列 }
    for var i := 0 to LVecDeque.Count - 2 do
      AssertTrue('元素应该按升序排列', LVecDeque.Get(i) <= LVecDeque.Get(i + 1));
  finally
    LVecDeque.Free;
  end;
end;

{ 高级容量和内存管理测试实现 }

procedure TTestCase_VecDeque.Test_ClearAndReserve;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LReserveCapacity: SizeUInt;
begin
  { 测试 ClearAndReserve - 清空并预留容量 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 准备测试数据 }
    for var i := 1 to 10 do
      LVecDeque.PushBack(i);

    LReserveCapacity := 20;

    { 执行清空并预留容量 }
    LVecDeque.ClearAndReserve(LReserveCapacity);

    { 验证结果 }
    AssertEquals('清空后元素数量应该为0', 0, LVecDeque.Count);
    AssertTrue('应该为空', LVecDeque.IsEmpty);
    AssertTrue('容量应该至少为预留值', LVecDeque.Capacity >= LReserveCapacity);

    { 验证可以使用预留的容量 }
    for var i := 0 to Integer(LReserveCapacity) - 1 do
      LVecDeque.PushBack(i);
    AssertEquals('应该能够添加预留数量的元素', LReserveCapacity, LVecDeque.Count);
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_ShrinkToFit;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LInitialCapacity, LAfterShrinkCapacity: SizeUInt;
begin
  { 测试 ShrinkToFit - 收缩到适合大小 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 预留大容量 }
    LVecDeque.Reserve(100);
    LInitialCapacity := LVecDeque.Capacity;

    { 只添加少量元素 }
    for var i := 1 to 5 do
      LVecDeque.PushBack(i);

    { 执行收缩到适合大小 }
    LVecDeque.ShrinkToFit;
    LAfterShrinkCapacity := LVecDeque.Capacity;

    { 验证结果 }
    AssertTrue('容量应该被减少', LAfterShrinkCapacity < LInitialCapacity);
    AssertTrue('容量应该仍然能容纳所有元素', LAfterShrinkCapacity >= LVecDeque.Count);
    AssertEquals('元素数量应该保持不变', 5, LVecDeque.Count);

    { 验证数据完整性 }
    for var i := 0 to LVecDeque.Count - 1 do
      AssertEquals('元素应该被保留', i + 1, LVecDeque.Get(i));
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_FastIndexOf;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LIndex: SizeUInt;
begin
  { 测试 FastIndexOf - 快速查找元素索引 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 准备测试数据 }
    LVecDeque.PushBack(10);
    LVecDeque.PushBack(20);
    LVecDeque.PushBack(30);
    LVecDeque.PushBack(20);
    LVecDeque.PushBack(40);

    { 快速查找存在的元素 }
    LIndex := LVecDeque.FastIndexOf(20);
    AssertEquals('应该找到第一个匹配元素的索引', SizeUInt(1), LIndex);

    { 查找第一个元素 }
    LIndex := LVecDeque.FastIndexOf(10);
    AssertEquals('应该找到第一个元素', SizeUInt(0), LIndex);

    { 查找最后一个元素 }
    LIndex := LVecDeque.FastIndexOf(40);
    AssertEquals('应该找到最后一个元素', SizeUInt(4), LIndex);

    { 查找不存在的元素 }
    LIndex := LVecDeque.FastIndexOf(99);
    AssertEquals('不存在的元素应该返回SIZE_MAX', SIZE_MAX, LIndex);
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_FastLastIndexOf;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LIndex: SizeUInt;
begin
  { 测试 FastLastIndexOf - 快速反向查找元素索引 }
  LVecDeque := specialize TVecDeque<Integer>;
  try
    { 准备测试数据 }
    LVecDeque.PushBack(10);
    LVecDeque.PushBack(20);
    LVecDeque.PushBack(30);
    LVecDeque.PushBack(20);
    LVecDeque.PushBack(40);
    LVecDeque.PushBack(20);

    { 快速反向查找存在的重复元素 }
    LIndex := LVecDeque.FastLastIndexOf(20);
    AssertEquals('应该找到最后一个匹配元素的索引', SizeUInt(5), LIndex);

    { 查找唯一元素 }
    LIndex := LVecDeque.FastLastIndexOf(30);
    AssertEquals('应该找到唯一元素', SizeUInt(2), LIndex);

    { 查找不存在的元素 }
    LIndex := LVecDeque.FastLastIndexOf(99);
    AssertEquals('不存在的元素应该返回SIZE_MAX', SIZE_MAX, LIndex);
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_FillWith;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LFillValue: Integer;
  LFillCount: SizeUInt;
begin
  { 测试 FillWith - 批量填充指定数量的元素 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    LFillValue := 42;
    LFillCount := 8;

    { 执行批量填充 }
    LVecDeque.FillWith(LFillValue, LFillCount);

    { 验证结果 }
    AssertEquals('元素数量应该等于填充数量', LFillCount, LVecDeque.Count);

    { 验证所有元素都是填充值 }
    for var i := 0 to LVecDeque.Count - 1 do
      AssertEquals('所有元素都应该是填充值', LFillValue, LVecDeque.Get(i));

    { 测试在现有数据基础上填充 }
    LVecDeque.FillWith(99, 3);
    AssertEquals('元素数量应该增加', LFillCount + 3, LVecDeque.Count);

    { 验证新填充的元素 }
    for var i := Integer(LFillCount) to LVecDeque.Count - 1 do
      AssertEquals('新填充的元素应该是新值', 99, LVecDeque.Get(i));
  finally
    LVecDeque.Free;
  end;
end;

{ 完成剩余的BinarySearchInsert系列测试实现 }

procedure TTestCase_VecDeque.Test_BinarySearchInsert_StartIndex_Element;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LInsertIndex, LStartIndex: SizeUInt;
begin
  { 测试 BinarySearchInsert_StartIndex_Element - 从指定索引开始二分查找插入位置 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 准备测试数据 - 前面部分未排序，后面部分已排序 }
    LVecDeque.PushBack(100);  { 未排序部分 }
    LVecDeque.PushBack(50);   { 未排序部分 }
    LVecDeque.PushBack(2);    { 排序部分开始 }
    LVecDeque.PushBack(4);
    LVecDeque.PushBack(6);
    LVecDeque.PushBack(10);
    LVecDeque.PushBack(12);

    LStartIndex := 2;

    { 从索引2开始查找插入位置 }
    LInsertIndex := LVecDeque.BinarySearchInsert(8, LStartIndex);
    AssertEquals('应该在排序部分的正确位置插入', SizeUInt(5), LInsertIndex);

    { 查找插入位置 - 在排序部分开头 }
    LInsertIndex := LVecDeque.BinarySearchInsert(1, LStartIndex);
    AssertEquals('应该在排序部分开头插入', SizeUInt(2), LInsertIndex);

    { 查找插入位置 - 在排序部分末尾 }
    LInsertIndex := LVecDeque.BinarySearchInsert(15, LStartIndex);
    AssertEquals('应该在排序部分末尾插入', SizeUInt(7), LInsertIndex);
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_BinarySearchInsert_StartIndex_Element_Func;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LInsertIndex, LStartIndex: SizeUInt;
begin
  { 测试 BinarySearchInsert_StartIndex_Element_Func - 从指定索引开始使用函数指针二分查找插入位置 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 准备测试数据 }
