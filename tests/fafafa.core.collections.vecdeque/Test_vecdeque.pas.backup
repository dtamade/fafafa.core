  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 准备测试数据 }
    for var i := 1 to 10 do
      LVecDeque.PushBack(i * 5);

    { 执行切片操作 }
    LSlice := LVecDeque.Slice(2, 4); { 从索引2开始，取4个元素 }
    try
      AssertNotNull('切片结果应该有效', LSlice);
      AssertEquals('切片元素数量应该正确', 4, LSlice.Count);

      { 验证切片内容 }
      AssertEquals('切片第一个元素应该正确', 15, LSlice.Get(0)); { 原索引2 }
      AssertEquals('切片第二个元素应该正确', 20, LSlice.Get(1)); { 原索引3 }
      AssertEquals('切片第三个元素应该正确', 25, LSlice.Get(2)); { 原索引4 }
      AssertEquals('切片第四个元素应该正确', 30, LSlice.Get(3)); { 原索引5 }

      { 验证独立性 }
      LSlice.Set(0, 999);
      AssertEquals('修改切片不应该影响原集合', 15, LVecDeque.Get(2));
    finally
      LSlice.Free;
    end;
  finally
    LVecDeque.Free;
  end;
end;

