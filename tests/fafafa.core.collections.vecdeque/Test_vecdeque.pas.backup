{ 全局函数声明 - 这些是真正的全局函数，不是类的成员 }
function ForEachTestFunc(const aValue: Integer; aData: Pointer): Boolean;
function EqualsTestFunc(const aValue1, aValue2: Integer; aData: Pointer): Boolean;
function CompareTestFunc(const aValue1, aValue2: Integer; aData: Pointer): SizeInt;
function PredicateTestFunc(const aValue: Integer; aData: Pointer): Boolean;

{ 引用函数声明 - 这些是引用类型的函数 }
function ForEachTestRefFunc(const aValue: Integer; aData: Pointer): Boolean;
function EqualsTestRefFunc(const aValue1, aValue2: Integer; aData: Pointer): Boolean;
function CompareTestRefFunc(const aValue1, aValue2: Integer; aData: Pointer): SizeInt;
function PredicateTestRefFunc(const aValue: Integer; aData: Pointer): Boolean;

{ 随机生成器函数声明 }
function RandomTestFunc(aData: Pointer): SizeUInt;
function RandomTestMethod(aData: Pointer): SizeUInt;
function RandomTestRefFunc(aData: Pointer): SizeUInt;

type

  { TTestCase_VecDeque - VecDeque完整测试套件
    
    测试组织原则：
    1. 每个接口方法都有对应的独立测试方法
    2. 测试方法命名直接对应接口方法名
    3. 按接口层次分组：ICollection -> IGenericCollection -> IQueue -> IDeque -> IVecDeque -> TVecDeque
