    AssertTrue('初始应该为空', LVecDeque.IsEmpty);
    AssertTrue('容量应该至少为指定值', LVecDeque.Capacity >= LInitialCapacity);

    { 测试在预留容量内添加元素 }
    for var i := 0 to Integer(LInitialCapacity) - 1 do
      LVecDeque.PushBack(i);

    AssertEquals('添加预留数量的元素后数量应该正确', LInitialCapacity, LVecDeque.Count);

    { 验证数据正确性 }
    for var i := 0 to LVecDeque.Count - 1 do
      AssertEquals('元素值应该正确', i, LVecDeque.Get(i));
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_Create_Capacity_Allocator;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LInitialCapacity: SizeUInt;
  LAllocator: IAllocator;
begin
  { 测试 Create_Capacity_Allocator - 使用初始容量和分配器的构造函数 }
  LInitialCapacity := 15;
  LAllocator := TDefaultAllocator.Create;
  LVecDeque := specialize TVecDeque<Integer>.Create(LInitialCapacity, LAllocator);
  try
    AssertNotNull('使用容量和分配器创建的VecDeque应该有效', LVecDeque);
    AssertEquals('初始元素数量应该为0', 0, LVecDeque.Count);
    AssertTrue('初始应该为空', LVecDeque.IsEmpty);
    AssertTrue('容量应该至少为指定值', LVecDeque.Capacity >= LInitialCapacity);

    { 测试基本操作 }
    for var i := 1 to 5 do
      LVecDeque.PushBack(i * 10);

    AssertEquals('添加5个元素后数量应该正确', 5, LVecDeque.Count);

    { 验证数据正确性 }
    for var i := 0 to LVecDeque.Count - 1 do
      AssertEquals('元素值应该正确', (i + 1) * 10, LVecDeque.Get(i));
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_Create_Capacity_Allocator_Data;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LInitialCapacity: SizeUInt;
  LAllocator: IAllocator;
  LData: Pointer;
begin
  { 测试 Create_Capacity_Allocator_Data - 使用容量、分配器和数据指针的构造函数 }
  LInitialCapacity := 25;
  LAllocator := TDefaultAllocator.Create;
  LData := @Self;
  LVecDeque := specialize TVecDeque<Integer>.Create(LInitialCapacity, LAllocator, LData);
  try
    AssertNotNull('使用容量、分配器和数据创建的VecDeque应该有效', LVecDeque);
    AssertEquals('初始元素数量应该为0', 0, LVecDeque.Count);
    AssertTrue('初始应该为空', LVecDeque.IsEmpty);
    AssertTrue('容量应该至少为指定值', LVecDeque.Capacity >= LInitialCapacity);

    { 测试双端操作 }
    LVecDeque.PushFront(100);
    LVecDeque.PushBack(200);
    LVecDeque.PushFront(50);
    LVecDeque.PushBack(250);

    AssertEquals('双端添加后数量应该正确', 4, LVecDeque.Count);
    AssertEquals('前端第一个元素应该正确', 50, LVecDeque.Get(0));
    AssertEquals('前端第二个元素应该正确', 100, LVecDeque.Get(1));
    AssertEquals('后端第一个元素应该正确', 200, LVecDeque.Get(2));
    AssertEquals('后端第二个元素应该正确', 250, LVecDeque.Get(3));
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_Create_Capacity_Allocator_GrowStrategy;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LInitialCapacity: SizeUInt;
  LAllocator: IAllocator;
  LGrowStrategy: TGrowStrategy;
begin
  { 测试 Create_Capacity_Allocator_GrowStrategy - 使用容量、分配器和增长策略的构造函数 }
  LInitialCapacity := 8;
  LAllocator := TDefaultAllocator.Create;
  LGrowStrategy := gsDouble;
  LVecDeque := specialize TVecDeque<Integer>.Create(LInitialCapacity, LAllocator, LGrowStrategy);
  try
    AssertNotNull('使用容量、分配器和增长策略创建的VecDeque应该有效', LVecDeque);
    AssertEquals('初始元素数量应该为0', 0, LVecDeque.Count);
    AssertTrue('容量应该至少为指定值', LVecDeque.Capacity >= LInitialCapacity);

    { 测试增长策略 - 超过初始容量 }
    for var i := 1 to 12 do
      LVecDeque.PushBack(i);

    AssertEquals('超过初始容量后数量应该正确', 12, LVecDeque.Count);
    AssertTrue('容量应该根据增长策略扩展', LVecDeque.Capacity > LInitialCapacity);

    { 验证数据正确性 }
    for var i := 0 to LVecDeque.Count - 1 do
      AssertEquals('元素值应该正确', i + 1, LVecDeque.Get(i));
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_Create_Capacity_Allocator_GrowStrategy_Data;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LInitialCapacity: SizeUInt;
  LAllocator: IAllocator;
  LGrowStrategy: TGrowStrategy;
  LData: Pointer;
begin
  { 测试 Create_Capacity_Allocator_GrowStrategy_Data - 使用所有参数的构造函数 }
  LInitialCapacity := 12;
  LAllocator := TDefaultAllocator.Create;
  LGrowStrategy := gsLinear;
  LData := @Self;
  LVecDeque := specialize TVecDeque<Integer>.Create(LInitialCapacity, LAllocator, LGrowStrategy, LData);
  try
    AssertNotNull('使用所有参数创建的VecDeque应该有效', LVecDeque);
    AssertEquals('初始元素数量应该为0', 0, LVecDeque.Count);
    AssertTrue('初始应该为空', LVecDeque.IsEmpty);
    AssertTrue('容量应该至少为指定值', LVecDeque.Capacity >= LInitialCapacity);

    { 测试复杂操作序列 }
    for var i := 1 to 5 do
      LVecDeque.PushBack(i);

    for var i := 10 to 12 do
      LVecDeque.PushFront(i);

    AssertEquals('复杂操作后数量应该正确', 8, LVecDeque.Count);

    { 验证前端元素 }
    AssertEquals('前端第一个元素应该正确', 12, LVecDeque.Get(0));
    AssertEquals('前端第二个元素应该正确', 11, LVecDeque.Get(1));
    AssertEquals('前端第三个元素应该正确', 10, LVecDeque.Get(2));

    { 验证后端元素 }
    AssertEquals('后端第一个元素应该正确', 1, LVecDeque.Get(3));
    AssertEquals('后端第二个元素应该正确', 2, LVecDeque.Get(4));
    AssertEquals('后端最后元素应该正确', 5, LVecDeque.Get(7));
  finally
    LVecDeque.Free;
  end;
end;

{ ===== 基础接口测试系列实现 ===== }

procedure TTestCase_VecDeque.Test_ICollection_Count;
var
  LVecDeque: specialize TVecDeque<Integer>;
begin
  { 测试 ICollection_Count - 元素计数接口 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 测试空容器计数 }
    AssertEquals('空容器计数应该为0', 0, LVecDeque.Count);

    { 测试添加元素后的计数 }
    LVecDeque.PushBack(1);
    AssertEquals('添加1个元素后计数应该为1', 1, LVecDeque.Count);

    LVecDeque.PushBack(2);
    LVecDeque.PushBack(3);
    AssertEquals('添加3个元素后计数应该为3', 3, LVecDeque.Count);

    { 测试删除元素后的计数 }
    LVecDeque.PopBack;
    AssertEquals('删除1个元素后计数应该为2', 2, LVecDeque.Count);

    { 测试清空后的计数 }
    LVecDeque.Clear;
    AssertEquals('清空后计数应该为0', 0, LVecDeque.Count);
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_ICollection_IsEmpty;
var
  LVecDeque: specialize TVecDeque<Integer>;
begin
  { 测试 ICollection_IsEmpty - 空状态检查接口 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 测试初始空状态 }
    AssertTrue('初始状态应该为空', LVecDeque.IsEmpty);

    { 测试添加元素后的状态 }
    LVecDeque.PushBack(42);
    AssertFalse('添加元素后应该不为空', LVecDeque.IsEmpty);

    { 测试删除元素后的状态 }
    LVecDeque.PopBack;
    AssertTrue('删除所有元素后应该为空', LVecDeque.IsEmpty);

    { 测试多次操作后的状态 }
    LVecDeque.PushFront(1);
    LVecDeque.PushBack(2);
    AssertFalse('添加多个元素后应该不为空', LVecDeque.IsEmpty);

    LVecDeque.Clear;
    AssertTrue('清空后应该为空', LVecDeque.IsEmpty);
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_ICollection_Clear;
var
  LVecDeque: specialize TVecDeque<Integer>;
begin
  { 测试 ICollection_Clear - 清空操作接口 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 测试空容器清空 }
    LVecDeque.Clear;
    AssertEquals('空容器清空后计数应该为0', 0, LVecDeque.Count);
    AssertTrue('空容器清空后应该为空', LVecDeque.IsEmpty);

    { 测试有元素容器的清空 }
    for var i := 1 to 10 do
      LVecDeque.PushBack(i);

    AssertEquals('添加元素后计数应该为10', 10, LVecDeque.Count);
    AssertFalse('添加元素后应该不为空', LVecDeque.IsEmpty);

    LVecDeque.Clear;
    AssertEquals('清空后计数应该为0', 0, LVecDeque.Count);
    AssertTrue('清空后应该为空', LVecDeque.IsEmpty);

    { 测试清空后可以继续使用 }
    LVecDeque.PushBack(99);
    AssertEquals('清空后添加元素计数应该为1', 1, LVecDeque.Count);
    AssertEquals('清空后添加的元素值应该正确', 99, LVecDeque.Get(0));
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_IGenericCollection_Add;
var
  LVecDeque: specialize TVecDeque<Integer>;
begin
  { 测试 IGenericCollection_Add - 泛型添加接口 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 测试添加单个元素 }
    LVecDeque.Add(10);
    AssertEquals('添加后计数应该为1', 1, LVecDeque.Count);
    AssertEquals('添加的元素值应该正确', 10, LVecDeque.Get(0));

    { 测试添加多个元素 }
    LVecDeque.Add(20);
    LVecDeque.Add(30);
    AssertEquals('添加多个元素后计数应该正确', 3, LVecDeque.Count);
    AssertEquals('第二个元素值应该正确', 20, LVecDeque.Get(1));
    AssertEquals('第三个元素值应该正确', 30, LVecDeque.Get(2));

    { 测试添加重复元素 }
    LVecDeque.Add(10);
    AssertEquals('添加重复元素后计数应该增加', 4, LVecDeque.Count);
    AssertEquals('重复元素值应该正确', 10, LVecDeque.Get(3));
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_IGenericCollection_Remove;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LRemoved: Boolean;
begin
  { 测试 IGenericCollection_Remove - 泛型移除接口 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 测试空容器移除 }
    LRemoved := LVecDeque.Remove(10);
    AssertFalse('空容器移除应该返回False', LRemoved);
    AssertEquals('空容器移除后计数应该为0', 0, LVecDeque.Count);

    { 准备测试数据 }
    LVecDeque.Add(10);
    LVecDeque.Add(20);
    LVecDeque.Add(30);
    LVecDeque.Add(20); { 重复元素 }

    { 测试移除存在的元素 }
    LRemoved := LVecDeque.Remove(20);
    AssertTrue('移除存在的元素应该返回True', LRemoved);
    AssertEquals('移除后计数应该减少', 3, LVecDeque.Count);

    { 验证移除的是第一个匹配的元素 }
    AssertEquals('第一个元素应该保持不变', 10, LVecDeque.Get(0));
    AssertEquals('第二个元素应该是30', 30, LVecDeque.Get(1));
    AssertEquals('第三个元素应该是剩余的20', 20, LVecDeque.Get(2));

    { 测试移除不存在的元素 }
    LRemoved := LVecDeque.Remove(99);
    AssertFalse('移除不存在的元素应该返回False', LRemoved);
    AssertEquals('移除不存在元素后计数应该不变', 3, LVecDeque.Count);
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_IGenericCollection_Contains;
var
  LVecDeque: specialize TVecDeque<Integer>;
begin
  { 测试 IGenericCollection_Contains - 泛型包含检查接口 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 测试空容器包含检查 }
    AssertFalse('空容器不应该包含任何元素', LVecDeque.Contains(10));

    { 准备测试数据 }
    LVecDeque.Add(10);
    LVecDeque.Add(20);
    LVecDeque.Add(30);

    { 测试包含存在的元素 }
    AssertTrue('应该包含存在的元素10', LVecDeque.Contains(10));
    AssertTrue('应该包含存在的元素20', LVecDeque.Contains(20));
    AssertTrue('应该包含存在的元素30', LVecDeque.Contains(30));

    { 测试不包含不存在的元素 }
    AssertFalse('不应该包含不存在的元素40', LVecDeque.Contains(40));
    AssertFalse('不应该包含不存在的元素0', LVecDeque.Contains(0));

    { 测试移除元素后的包含检查 }
    LVecDeque.Remove(20);
    AssertFalse('移除后不应该包含该元素', LVecDeque.Contains(20));
    AssertTrue('移除后应该仍包含其他元素', LVecDeque.Contains(10));
    AssertTrue('移除后应该仍包含其他元素', LVecDeque.Contains(30));
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_IQueue_Enqueue;
var
  LVecDeque: specialize TVecDeque<Integer>;
begin
  { 测试 IQueue_Enqueue - 队列入队接口 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 测试入队操作 }
    LVecDeque.Enqueue(100);
    AssertEquals('入队后计数应该为1', 1, LVecDeque.Count);
    AssertEquals('入队的元素应该在队尾', 100, LVecDeque.Back);

    { 测试多次入队 }
    LVecDeque.Enqueue(200);
    LVecDeque.Enqueue(300);
    AssertEquals('多次入队后计数应该正确', 3, LVecDeque.Count);

    { 验证队列顺序 (FIFO) }
    AssertEquals('队首应该是第一个入队的元素', 100, LVecDeque.Front);
    AssertEquals('队尾应该是最后入队的元素', 300, LVecDeque.Back);

    { 验证中间元素 }
    AssertEquals('中间元素应该正确', 200, LVecDeque.Get(1));
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_IQueue_Dequeue;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LValue: Integer;
begin
  { 测试 IQueue_Dequeue - 队列出队接口 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 准备测试数据 }
    LVecDeque.Enqueue(100);
    LVecDeque.Enqueue(200);
    LVecDeque.Enqueue(300);

    { 测试出队操作 (FIFO) }
    LValue := LVecDeque.Dequeue;
    AssertEquals('第一次出队应该得到第一个入队的元素', 100, LValue);
    AssertEquals('出队后计数应该减少', 2, LVecDeque.Count);

    LValue := LVecDeque.Dequeue;
    AssertEquals('第二次出队应该得到第二个入队的元素', 200, LValue);
    AssertEquals('出队后计数应该继续减少', 1, LVecDeque.Count);

    LValue := LVecDeque.Dequeue;
    AssertEquals('第三次出队应该得到最后一个元素', 300, LValue);
    AssertEquals('出队后应该为空', 0, LVecDeque.Count);
    AssertTrue('出队后应该为空状态', LVecDeque.IsEmpty);
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_IQueue_Peek;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LValue: Integer;
begin
  { 测试 IQueue_Peek - 队列查看接口 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 准备测试数据 }
    LVecDeque.Enqueue(500);
    LVecDeque.Enqueue(600);

    { 测试查看操作 }
    LValue := LVecDeque.Peek;
    AssertEquals('查看应该返回队首元素', 500, LValue);
    AssertEquals('查看后计数应该不变', 2, LVecDeque.Count);

    { 验证查看不改变队列状态 }
    LValue := LVecDeque.Peek;
    AssertEquals('再次查看应该返回相同元素', 500, LValue);
    AssertEquals('再次查看后计数应该仍不变', 2, LVecDeque.Count);

    { 验证查看与出队的一致性 }
    var LPeekedValue := LVecDeque.Peek;
    var LDequeuedValue := LVecDeque.Dequeue;
    AssertEquals('查看的值应该与出队的值相同', LPeekedValue, LDequeuedValue);
  finally
    LVecDeque.Free;
  end;
end;

{ ===== IDeque接口测试系列实现 ===== }

procedure TTestCase_VecDeque.Test_IDeque_PushFront;
var
  LVecDeque: specialize TVecDeque<Integer>;
begin
  { 测试 IDeque_PushFront - 双端队列前端推入接口 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 测试前端推入单个元素 }
    LVecDeque.PushFront(100);
    AssertEquals('前端推入后计数应该为1', 1, LVecDeque.Count);
    AssertEquals('前端推入的元素应该在前端', 100, LVecDeque.Front);
    AssertEquals('前端推入的元素应该在索引0', 100, LVecDeque.Get(0));

    { 测试多次前端推入 }
    LVecDeque.PushFront(200);
    LVecDeque.PushFront(300);
    AssertEquals('多次前端推入后计数应该正确', 3, LVecDeque.Count);

    { 验证前端推入的顺序 (后进先出) }
    AssertEquals('最后推入的元素应该在前端', 300, LVecDeque.Front);
    AssertEquals('索引0应该是最后推入的元素', 300, LVecDeque.Get(0));
    AssertEquals('索引1应该是倒数第二个推入的元素', 200, LVecDeque.Get(1));
    AssertEquals('索引2应该是第一个推入的元素', 100, LVecDeque.Get(2));
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_IDeque_PushBack;
var
  LVecDeque: specialize TVecDeque<Integer>;
begin
  { 测试 IDeque_PushBack - 双端队列后端推入接口 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 测试后端推入单个元素 }
    LVecDeque.PushBack(400);
    AssertEquals('后端推入后计数应该为1', 1, LVecDeque.Count);
    AssertEquals('后端推入的元素应该在后端', 400, LVecDeque.Back);
    AssertEquals('后端推入的元素应该在索引0', 400, LVecDeque.Get(0));

    { 测试多次后端推入 }
    LVecDeque.PushBack(500);
    LVecDeque.PushBack(600);
    AssertEquals('多次后端推入后计数应该正确', 3, LVecDeque.Count);

    { 验证后端推入的顺序 (先进先出) }
    AssertEquals('第一个推入的元素应该在前端', 400, LVecDeque.Front);
    AssertEquals('最后推入的元素应该在后端', 600, LVecDeque.Back);
    AssertEquals('索引0应该是第一个推入的元素', 400, LVecDeque.Get(0));
    AssertEquals('索引1应该是第二个推入的元素', 500, LVecDeque.Get(1));
    AssertEquals('索引2应该是最后推入的元素', 600, LVecDeque.Get(2));
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_IDeque_PopFront;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LValue: Integer;
begin
  { 测试 IDeque_PopFront - 双端队列前端弹出接口 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 准备测试数据 }
    LVecDeque.PushBack(100);
    LVecDeque.PushBack(200);
    LVecDeque.PushBack(300);

    { 测试前端弹出 }
    LValue := LVecDeque.PopFront;
    AssertEquals('前端弹出应该得到前端元素', 100, LValue);
    AssertEquals('前端弹出后计数应该减少', 2, LVecDeque.Count);
    AssertEquals('前端弹出后新的前端应该正确', 200, LVecDeque.Front);

    { 测试连续前端弹出 }
    LValue := LVecDeque.PopFront;
    AssertEquals('第二次前端弹出应该得到新的前端元素', 200, LValue);
    AssertEquals('第二次前端弹出后计数应该继续减少', 1, LVecDeque.Count);
    AssertEquals('第二次前端弹出后新的前端应该正确', 300, LVecDeque.Front);

    { 测试弹出最后一个元素 }
    LValue := LVecDeque.PopFront;
    AssertEquals('弹出最后一个元素应该正确', 300, LValue);
    AssertEquals('弹出最后一个元素后应该为空', 0, LVecDeque.Count);
    AssertTrue('弹出最后一个元素后应该为空状态', LVecDeque.IsEmpty);
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_IDeque_PopBack;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LValue: Integer;
begin
  { 测试 IDeque_PopBack - 双端队列后端弹出接口 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 准备测试数据 }
    LVecDeque.PushBack(700);
    LVecDeque.PushBack(800);
    LVecDeque.PushBack(900);

    { 测试后端弹出 }
    LValue := LVecDeque.PopBack;
    AssertEquals('后端弹出应该得到后端元素', 900, LValue);
    AssertEquals('后端弹出后计数应该减少', 2, LVecDeque.Count);
    AssertEquals('后端弹出后新的后端应该正确', 800, LVecDeque.Back);

    { 测试连续后端弹出 }
    LValue := LVecDeque.PopBack;
    AssertEquals('第二次后端弹出应该得到新的后端元素', 800, LValue);
    AssertEquals('第二次后端弹出后计数应该继续减少', 1, LVecDeque.Count);
    AssertEquals('第二次后端弹出后新的后端应该正确', 700, LVecDeque.Back);

    { 测试弹出最后一个元素 }
    LValue := LVecDeque.PopBack;
    AssertEquals('弹出最后一个元素应该正确', 700, LValue);
    AssertEquals('弹出最后一个元素后应该为空', 0, LVecDeque.Count);
    AssertTrue('弹出最后一个元素后应该为空状态', LVecDeque.IsEmpty);
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_IDeque_PeekFront;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LValue: Integer;
begin
  { 测试 IDeque_PeekFront - 双端队列前端查看接口 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 准备测试数据 }
    LVecDeque.PushBack(1000);
    LVecDeque.PushBack(2000);

    { 测试前端查看 }
    LValue := LVecDeque.PeekFront;
    AssertEquals('前端查看应该返回前端元素', 1000, LValue);
    AssertEquals('前端查看后计数应该不变', 2, LVecDeque.Count);

    { 验证查看不改变状态 }
    LValue := LVecDeque.PeekFront;
    AssertEquals('再次前端查看应该返回相同元素', 1000, LValue);
    AssertEquals('再次前端查看后计数应该仍不变', 2, LVecDeque.Count);

    { 验证查看与弹出的一致性 }
    var LPeekedValue := LVecDeque.PeekFront;
    var LPoppedValue := LVecDeque.PopFront;
    AssertEquals('前端查看的值应该与前端弹出的值相同', LPeekedValue, LPoppedValue);
  finally
    LVecDeque.Free;
  end;
end;

