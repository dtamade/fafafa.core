    AssertEquals('第一个元素应该被替换', 70, LVecDeque.Get(0));
    AssertEquals('第二个元素应该保持不变', 14, LVecDeque.Get(1));
    AssertEquals('第三个元素应该被替换', 70, LVecDeque.Get(2));
    AssertEquals('第四个元素应该保持不变', 21, LVecDeque.Get(3));
    AssertEquals('第五个元素应该被替换', 70, LVecDeque.Get(4));
