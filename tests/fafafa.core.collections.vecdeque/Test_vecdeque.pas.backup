procedure TTestCase_VecDeque.Test_Create_Pointer_Count_Allocator_GrowStrategy;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LArray: array[0..2] of Integer;
  LPointer: Pointer;
  LCount: SizeUInt;
  LAllocator: IAllocator;
  LGrowStrategy: TGrowStrategy;
begin
  { 测试 Create_Pointer_Count_Allocator_GrowStrategy - 使用指针、数量、分配器和增长策略的构造函数 }
  for var i := 0 to High(LArray) do
    LArray[i] := (i + 1) * 23;

  LPointer := @LArray[0];
  LCount := Length(LArray);
  LAllocator := TDefaultAllocator.Create;
  LGrowStrategy := gsDouble;

  LVecDeque := specialize TVecDeque<Integer>.Create(LPointer, LCount, LAllocator, LGrowStrategy);
  try
    AssertNotNull('使用指针、数量、分配器和增长策略创建的VecDeque应该有效', LVecDeque);
    AssertEquals('元素数量应该等于指定数量', LCount, LVecDeque.Count);

    { 验证数据被正确复制 }
    for var i := 0 to High(LArray) do
      AssertEquals('指针数据应该被正确复制', LArray[i], LVecDeque.Get(i));

    { 测试增长策略 }
    var LOriginalCapacity := LVecDeque.Capacity;
    for var i := 1 to 10 do
      LVecDeque.PushBack(i * 1000);
    AssertTrue('增长策略应该生效', LVecDeque.Capacity > LOriginalCapacity);
  finally
    LVecDeque.Free;
  end;
end;

