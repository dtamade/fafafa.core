procedure TTestCase_VecDeque.Test_Shuffle_StartIndex_Count;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LStartIndex, LCount: SizeUInt;
begin
  { 测试 Shuffle_StartIndex_Count - 在指定范围内随机打乱 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 准备测试数据 }
    for var i := 1 to 10 do
      LVecDeque.PushBack(i);

    LStartIndex := 3;
    LCount := 5;

    { 执行指定范围的打乱 }
    LVecDeque.Shuffle(LStartIndex, LCount);

    { 验证结果 }
    AssertEquals('元素数量应该保持不变', 10, LVecDeque.Count);

    { 范围外的元素应该保持不变 }
    for var i := 0 to Integer(LStartIndex) - 1 do
      AssertEquals('范围前的元素应该保持不变', i + 1, LVecDeque.Get(i));

    for var i := Integer(LStartIndex + LCount) to LVecDeque.Count - 1 do
      AssertEquals('范围后的元素应该保持不变', i + 1, LVecDeque.Get(i));

    { 范围内的元素应该仍然存在（但可能顺序改变） }
    for var i := Integer(LStartIndex) + 1 to Integer(LStartIndex + LCount) do
    begin
      var LFound := False;
      for var j := Integer(LStartIndex) to Integer(LStartIndex + LCount) - 1 do
      begin
        if LVecDeque.Get(j) = i then
        begin
          LFound := True;
          Break;
        end;
      end;
      AssertTrue('范围内的元素应该仍然存在', LFound);
    end;
  finally
    LVecDeque.Free;
  end;
end;

