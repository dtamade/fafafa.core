procedure TTestCase_VecDeque.Test_Insert_Index_Collection;
var
  LVecDeque1, LVecDeque2: specialize TVecDeque<Integer>;
begin
  { 测试 Insert_Index_Collection - 在指定索引插入另一个集合 }
  LVecDeque1 := specialize TVecDeque<Integer>.Create;
  LVecDeque2 := specialize TVecDeque<Integer>.Create;
  try
    { 准备主集合 }
    LVecDeque1.PushBack(10);
    LVecDeque1.PushBack(30);

    { 准备插入集合 }
    LVecDeque2.PushBack(15);
    LVecDeque2.PushBack(20);
    LVecDeque2.PushBack(25);

    { 在中间插入集合 }
    LVecDeque1.Insert(1, LVecDeque2);
    AssertEquals('插入集合后元素数量应该正确', 5, LVecDeque1.Count);

    { 验证插入结果 }
    AssertEquals('第一个元素应该保持不变', 10, LVecDeque1.Get(0));
    AssertEquals('插入的第一个元素应该正确', 15, LVecDeque1.Get(1));
    AssertEquals('插入的第二个元素应该正确', 20, LVecDeque1.Get(2));
    AssertEquals('插入的第三个元素应该正确', 25, LVecDeque1.Get(3));
    AssertEquals('原来的第二个元素应该后移', 30, LVecDeque1.Get(4));

    { 验证源集合不受影响 }
    AssertEquals('源集合应该保持不变', 3, LVecDeque2.Count);
  finally
    LVecDeque1.Free;
    LVecDeque2.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_Write_Index_Collection;
