    LVecDeque.PushBack(15);
    LVecDeque.PushBack(25);
    LVecDeque.PushBack(15);
    LVecDeque.PushBack(35);

    { 使用函数指针查找存在的元素 }
    LIndex := LVecDeque.FindUnChecked(15, @EqualsTestFunc, @Self);
    AssertEquals('应该找到第一个匹配元素的索引', SizeUInt(1), LIndex);

    { 查找不存在的元素 }
    LIndex := LVecDeque.FindUnChecked(99, @EqualsTestFunc, @Self);
    AssertEquals('不存在的元素应该返回SIZE_MAX', SIZE_MAX, LIndex);
  finally
    LVecDeque.Free;
  end;
end;

