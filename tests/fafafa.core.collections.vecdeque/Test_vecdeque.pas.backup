{ ===== 高级操作测试系列实现 ===== }

procedure TTestCase_VecDeque.Test_Insert_Index_Element;
var
  LVecDeque: specialize TVecDeque<Integer>;
begin
  { 测试 Insert_Index_Element - 在指定索引插入单个元素 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 测试在空容器中插入 }
    LVecDeque.Insert(0, 100);
    AssertEquals('在空容器插入后计数应该为1', 1, LVecDeque.Count);
    AssertEquals('插入的元素值应该正确', 100, LVecDeque.Get(0));

    { 测试在开头插入 }
    LVecDeque.Insert(0, 50);
    AssertEquals('在开头插入后计数应该为2', 2, LVecDeque.Count);
    AssertEquals('在开头插入的元素应该在索引0', 50, LVecDeque.Get(0));
    AssertEquals('原来的元素应该后移', 100, LVecDeque.Get(1));

    { 测试在中间插入 }
    LVecDeque.Insert(1, 75);
    AssertEquals('在中间插入后计数应该为3', 3, LVecDeque.Count);
    AssertEquals('第一个元素应该保持不变', 50, LVecDeque.Get(0));
    AssertEquals('在中间插入的元素应该正确', 75, LVecDeque.Get(1));
    AssertEquals('后面的元素应该后移', 100, LVecDeque.Get(2));

    { 测试在末尾插入 }
    LVecDeque.Insert(3, 150);
    AssertEquals('在末尾插入后计数应该为4', 4, LVecDeque.Count);
    AssertEquals('在末尾插入的元素应该正确', 150, LVecDeque.Get(3));
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_Insert_Index_Array;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LArray: array[0..2] of Integer;
begin
  { 测试 Insert_Index_Array - 在指定索引插入数组 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 准备测试数组 }
    LArray[0] := 10;
    LArray[1] := 20;
    LArray[2] := 30;

    { 准备初始数据 }
    LVecDeque.PushBack(100);
    LVecDeque.PushBack(200);

    { 测试在中间插入数组 }
    LVecDeque.Insert(1, LArray);
    AssertEquals('插入数组后计数应该正确', 5, LVecDeque.Count);

    { 验证插入结果 }
    AssertEquals('第一个元素应该保持不变', 100, LVecDeque.Get(0));
    AssertEquals('插入的第一个数组元素应该正确', 10, LVecDeque.Get(1));
    AssertEquals('插入的第二个数组元素应该正确', 20, LVecDeque.Get(2));
    AssertEquals('插入的第三个数组元素应该正确', 30, LVecDeque.Get(3));
    AssertEquals('原来的第二个元素应该后移', 200, LVecDeque.Get(4));
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_Remove_Index_Count;
var
  LVecDeque: specialize TVecDeque<Integer>;
begin
  { 测试 Remove_Index_Count - 从指定索引移除指定数量的元素 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 准备测试数据 }
    for var i := 1 to 10 do
      LVecDeque.PushBack(i * 10);

    { 测试从中间移除多个元素 }
    LVecDeque.Remove(2, 3); { 移除索引2-4的元素 (30, 40, 50) }
    AssertEquals('移除后计数应该正确', 7, LVecDeque.Count);

    { 验证移除结果 }
    AssertEquals('前面的元素应该保持不变', 10, LVecDeque.Get(0));
    AssertEquals('前面的元素应该保持不变', 20, LVecDeque.Get(1));
    AssertEquals('移除后的元素应该前移', 60, LVecDeque.Get(2));
    AssertEquals('移除后的元素应该前移', 70, LVecDeque.Get(3));
    AssertEquals('后面的元素应该保持相对位置', 100, LVecDeque.Get(6));

    { 测试从开头移除 }
    LVecDeque.Remove(0, 2); { 移除前两个元素 }
    AssertEquals('从开头移除后计数应该正确', 5, LVecDeque.Count);
    AssertEquals('移除后第一个元素应该正确', 60, LVecDeque.Get(0));
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_Write_Index_Array;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LArray: array[0..2] of Integer;
begin
  { 测试 Write_Index_Array - 在指定索引写入数组 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 准备测试数据 }
    for var i := 1 to 6 do
      LVecDeque.PushBack(i);

    { 准备写入数组 }
    LArray[0] := 100;
    LArray[1] := 200;
    LArray[2] := 300;

    { 测试在中间写入数组 }
    LVecDeque.Write(2, LArray);
    AssertEquals('写入后计数应该保持不变', 6, LVecDeque.Count);

    { 验证写入结果 }
    AssertEquals('前面的元素应该保持不变', 1, LVecDeque.Get(0));
    AssertEquals('前面的元素应该保持不变', 2, LVecDeque.Get(1));
    AssertEquals('写入的第一个元素应该正确', 100, LVecDeque.Get(2));
    AssertEquals('写入的第二个元素应该正确', 200, LVecDeque.Get(3));
    AssertEquals('写入的第三个元素应该正确', 300, LVecDeque.Get(4));
    AssertEquals('后面的元素应该保持不变', 6, LVecDeque.Get(5));
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_Resize_Count;
var
  LVecDeque: specialize TVecDeque<Integer>;
begin
  { 测试 Resize_Count - 调整容器大小 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 测试从空容器调整大小 }
    LVecDeque.Resize(5);
    AssertEquals('调整大小后计数应该正确', 5, LVecDeque.Count);

    { 验证新元素的默认值 }
    for var i := 0 to LVecDeque.Count - 1 do
      AssertEquals('新元素应该是默认值', 0, LVecDeque.Get(i));

    { 准备测试数据 }
    for var i := 0 to LVecDeque.Count - 1 do
      LVecDeque.Set(i, (i + 1) * 10);

    { 测试扩大大小 }
    LVecDeque.Resize(8);
    AssertEquals('扩大后计数应该正确', 8, LVecDeque.Count);

    { 验证原有数据保持不变 }
    for var i := 0 to 4 do
      AssertEquals('原有数据应该保持不变', (i + 1) * 10, LVecDeque.Get(i));

    { 验证新增元素是默认值 }
    for var i := 5 to 7 do
      AssertEquals('新增元素应该是默认值', 0, LVecDeque.Get(i));

    { 测试缩小大小 }
    LVecDeque.Resize(3);
    AssertEquals('缩小后计数应该正确', 3, LVecDeque.Count);

    { 验证保留的数据正确 }
    for var i := 0 to 2 do
      AssertEquals('保留的数据应该正确', (i + 1) * 10, LVecDeque.Get(i));
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_Resize_Count_Value;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LFillValue: Integer;
begin
  { 测试 Resize_Count_Value - 使用指定值调整容器大小 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    LFillValue := 42;

    { 测试从空容器调整大小并填充指定值 }
    LVecDeque.Resize(4, LFillValue);
    AssertEquals('调整大小后计数应该正确', 4, LVecDeque.Count);

    { 验证填充值 }
    for var i := 0 to LVecDeque.Count - 1 do
      AssertEquals('新元素应该是指定填充值', LFillValue, LVecDeque.Get(i));

    { 测试扩大大小并填充新值 }
    var LNewFillValue := 99;
    LVecDeque.Resize(7, LNewFillValue);
    AssertEquals('扩大后计数应该正确', 7, LVecDeque.Count);

    { 验证原有数据保持不变 }
    for var i := 0 to 3 do
      AssertEquals('原有数据应该保持不变', LFillValue, LVecDeque.Get(i));

    { 验证新增元素是新填充值 }
    for var i := 4 to 6 do
      AssertEquals('新增元素应该是新填充值', LNewFillValue, LVecDeque.Get(i));
  finally
    LVecDeque.Free;
  end;
end;

{ ===== 性能和压力测试系列实现 ===== }

procedure TTestCase_VecDeque.Test_Performance_Large_PushBack;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LStartTime, LEndTime: TDateTime;
  LElementCount: SizeUInt;
begin
  { 测试 Performance_Large_PushBack - 大量后端推入性能测试 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    LElementCount := 100000; { 10万个元素 }

    { 记录开始时间 }
    LStartTime := Now;

    { 执行大量后端推入 }
    for var i := 0 to Integer(LElementCount) - 1 do
      LVecDeque.PushBack(i);

    { 记录结束时间 }
    LEndTime := Now;

    { 验证结果 }
    AssertEquals('大量推入后元素数量应该正确', LElementCount, LVecDeque.Count);

    { 抽样验证数据正确性 }
    for var i := 0 to 99 do
    begin
      var LIndex := (i * Integer(LElementCount)) div 100;
      AssertEquals('抽样元素值应该正确', LIndex, LVecDeque.Get(LIndex));
    end;

    { 性能验证 - 操作应该在合理时间内完成 }
    var LElapsedMs := MilliSecondsBetween(LEndTime, LStartTime);
    AssertTrue('大量推入操作应该在合理时间内完成', LElapsedMs < 5000); { 5秒内 }
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_Performance_Large_PushFront;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LStartTime, LEndTime: TDateTime;
  LElementCount: SizeUInt;
begin
  { 测试 Performance_Large_PushFront - 大量前端推入性能测试 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    LElementCount := 50000; { 5万个元素 }

    { 记录开始时间 }
    LStartTime := Now;

    { 执行大量前端推入 }
    for var i := 0 to Integer(LElementCount) - 1 do
      LVecDeque.PushFront(i);

    { 记录结束时间 }
    LEndTime := Now;

    { 验证结果 }
    AssertEquals('大量前端推入后元素数量应该正确', LElementCount, LVecDeque.Count);

    { 验证前端推入的顺序 (后进先出) }
    for var i := 0 to 99 do
    begin
      var LExpectedValue := Integer(LElementCount) - 1 - i;
      AssertEquals('前端推入的元素顺序应该正确', LExpectedValue, LVecDeque.Get(i));
    end;

    { 性能验证 }
    var LElapsedMs := MilliSecondsBetween(LEndTime, LStartTime);
    AssertTrue('大量前端推入操作应该在合理时间内完成', LElapsedMs < 5000);
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_Performance_Mixed_Operations;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LStartTime, LEndTime: TDateTime;
  LOperationCount: SizeUInt;
begin
  { 测试 Performance_Mixed_Operations - 混合操作性能测试 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    LOperationCount := 20000; { 2万次操作 }

    { 记录开始时间 }
    LStartTime := Now;

    { 执行混合操作 }
    for var i := 0 to Integer(LOperationCount) - 1 do
    begin
      case i mod 6 of
        0: LVecDeque.PushBack(i);
        1: LVecDeque.PushFront(i);
        2: if not LVecDeque.IsEmpty then LVecDeque.PopBack;
        3: if not LVecDeque.IsEmpty then LVecDeque.PopFront;
        4: if not LVecDeque.IsEmpty then var LValue := LVecDeque.Get(LVecDeque.Count div 2);
        5: if LVecDeque.Count > 0 then LVecDeque.Set(LVecDeque.Count div 2, i);
      end;
    end;

    { 记录结束时间 }
    LEndTime := Now;

    { 验证容器仍然有效 }
    AssertTrue('混合操作后容器应该仍然有效', LVecDeque.Count >= 0);

    { 性能验证 }
    var LElapsedMs := MilliSecondsBetween(LEndTime, LStartTime);
    AssertTrue('混合操作应该在合理时间内完成', LElapsedMs < 3000);
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_Stress_Memory_Allocation;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LInitialCapacity, LFinalCapacity: SizeUInt;
begin
  { 测试 Stress_Memory_Allocation - 内存分配压力测试 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    LInitialCapacity := LVecDeque.Capacity;

    { 执行多轮增长和收缩 }
    for var Round := 1 to 10 do
    begin
      { 增长阶段 }
      for var i := 1 to 1000 do
        LVecDeque.PushBack(Round * 1000 + i);

      { 验证增长后的状态 }
      AssertEquals('增长后元素数量应该正确', Round * 1000, LVecDeque.Count);
      AssertTrue('增长后容量应该足够', LVecDeque.Capacity >= LVecDeque.Count);

      { 收缩阶段 }
      for var i := 1 to 500 do
        if not LVecDeque.IsEmpty then LVecDeque.PopBack;

      { 验证收缩后的状态 }
      AssertEquals('收缩后元素数量应该正确', Round * 500, LVecDeque.Count);
    end;

    LFinalCapacity := LVecDeque.Capacity;

    { 验证内存管理的合理性 }
    AssertTrue('最终容量应该合理', LFinalCapacity >= LVecDeque.Count);

    { 验证数据完整性 }
    for var i := 0 to Min(99, LVecDeque.Count - 1) do
    begin
      var LValue := LVecDeque.Get(i);
      AssertTrue('数据应该在合理范围内', (LValue > 0) and (LValue <= 10000));
    end;
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_Stress_Capacity_Management;
var
  LVecDeque: specialize TVecDeque<Integer>;
begin
  { 测试 Stress_Capacity_Management - 容量管理压力测试 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 测试频繁的容量调整 }
    for var i := 1 to 20 do
    begin
      var LTargetCapacity := i * 100;

      { 预留容量 }
      LVecDeque.Reserve(LTargetCapacity);
      AssertTrue('预留后容量应该足够', LVecDeque.Capacity >= LTargetCapacity);

      { 填充到容量 }
      while LVecDeque.Count < LTargetCapacity do
        LVecDeque.PushBack(LVecDeque.Count);

      AssertEquals('填充后数量应该正确', LTargetCapacity, LVecDeque.Count);

      { 收缩容量 }
      if i mod 3 = 0 then
      begin
        LVecDeque.ShrinkToFit;
        AssertTrue('收缩后容量应该合理', LVecDeque.Capacity >= LVecDeque.Count);
      end;

      { 部分清空 }
      if i mod 2 = 0 then
      begin
        for var j := 1 to 50 do
          if not LVecDeque.IsEmpty then LVecDeque.PopBack;
      end;
    end;

    { 最终验证 }
    AssertTrue('压力测试后容器应该仍然有效', LVecDeque.Count >= 0);
    AssertTrue('压力测试后容量应该合理', LVecDeque.Capacity >= LVecDeque.Count);
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_Boundary_Index_Access;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LExceptionRaised: Boolean;
begin
  { 测试 Boundary_Index_Access - 边界索引访问测试 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 准备测试数据 }
    for var i := 1 to 5 do
      LVecDeque.PushBack(i * 10);

    { 测试有效索引访问 }
    AssertEquals('第一个元素访问应该正确', 10, LVecDeque.Get(0));
    AssertEquals('最后一个元素访问应该正确', 50, LVecDeque.Get(4));
    AssertEquals('中间元素访问应该正确', 30, LVecDeque.Get(2));

    { 测试边界索引访问 }
    LExceptionRaised := False;
    try
      var LValue := LVecDeque.Get(5); { 超出范围 }
    except
      on E: Exception do
        LExceptionRaised := True;
    end;
    AssertTrue('超出范围的索引访问应该抛出异常', LExceptionRaised);

    { 测试负索引访问 (如果支持) }
    LExceptionRaised := False;
    try
      var LValue := LVecDeque.Get(SIZE_MAX); { 非常大的索引 }
    except
      on E: Exception do
        LExceptionRaised := True;
    end;
    AssertTrue('非法索引访问应该抛出异常', LExceptionRaised);

    { 测试空容器访问 }
    LVecDeque.Clear;
    LExceptionRaised := False;
    try
      var LValue := LVecDeque.Get(0); { 空容器访问 }
    except
      on E: Exception do
        LExceptionRaised := True;
    end;
    AssertTrue('空容器索引访问应该抛出异常', LExceptionRaised);
  finally
    LVecDeque.Free;
  end;
end;

{ ===== 回归测试系列实现 ===== }

procedure TTestCase_VecDeque.Test_Regression_Bug_001;
var
  LVecDeque: specialize TVecDeque<Integer>;
begin
  { 测试 Regression_Bug_001 - 修复空容器前端弹出崩溃问题 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 模拟Bug场景：空容器连续弹出操作 }
    var LExceptionRaised := False;
    try
      LVecDeque.PopFront; { 应该抛出异常而不是崩溃 }
    except
      on E: Exception do
        LExceptionRaised := True;
    end;
    AssertTrue('空容器前端弹出应该抛出异常', LExceptionRaised);

    { 验证容器状态仍然正常 }
    AssertEquals('异常后容器计数应该为0', 0, LVecDeque.Count);
    AssertTrue('异常后容器应该为空', LVecDeque.IsEmpty);

    { 验证后续操作正常 }
    LVecDeque.PushBack(42);
    AssertEquals('异常后添加元素应该正常', 1, LVecDeque.Count);
    AssertEquals('异常后元素值应该正确', 42, LVecDeque.Get(0));
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_Regression_Bug_002;
var
  LVecDeque: specialize TVecDeque<Integer>;
begin
  { 测试 Regression_Bug_002 - 修复容量溢出导致的内存错误 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 模拟Bug场景：尝试预留过大容量 }
    var LExceptionRaised := False;
    try
      { 尝试预留一个可能导致溢出的大容量 }
      LVecDeque.Reserve(SIZE_MAX div 2);
    except
      on E: Exception do
        LExceptionRaised := True;
    end;

    { 验证容器仍然可用 }
    AssertTrue('容器应该仍然有效', LVecDeque.Count >= 0);

    { 验证正常操作仍然工作 }
    LVecDeque.PushBack(100);
    LVecDeque.PushBack(200);
    AssertEquals('正常操作应该仍然工作', 2, LVecDeque.Count);
    AssertEquals('元素值应该正确', 100, LVecDeque.Get(0));
    AssertEquals('元素值应该正确', 200, LVecDeque.Get(1));
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_Regression_Bug_003;
var
  LVecDeque: specialize TVecDeque<Integer>;
begin
  { 测试 Regression_Bug_003 - 修复频繁前端操作导致的性能退化 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 模拟Bug场景：频繁的前端推入和弹出 }
    var LStartTime := Now;

    { 执行大量前端操作 }
    for var i := 1 to 1000 do
    begin
      LVecDeque.PushFront(i);
      if i mod 2 = 0 then
        LVecDeque.PopFront;
    end;

    var LEndTime := Now;
    var LElapsedMs := MilliSecondsBetween(LEndTime, LStartTime);

    { 验证性能在合理范围内 }
    AssertTrue('频繁前端操作应该在合理时间内完成', LElapsedMs < 1000);

    { 验证最终状态正确 }
    AssertEquals('频繁操作后元素数量应该正确', 500, LVecDeque.Count);

    { 验证数据完整性 }
    for var i := 0 to Min(9, LVecDeque.Count - 1) do
    begin
      var LValue := LVecDeque.Get(i);
      AssertTrue('元素值应该在合理范围内', LValue > 0);
    end;
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_Regression_Memory_Leak;
var
  LVecDeques: array[0..99] of specialize TVecDeque<Integer>;
begin
  { 测试 Regression_Memory_Leak - 验证内存泄漏修复 }
  try
    { 创建大量容器实例 }
    for var i := 0 to High(LVecDeques) do
    begin
      LVecDeques[i] := specialize TVecDeque<Integer>.Create;

      { 添加一些数据 }
      for var j := 1 to 100 do
        LVecDeques[i].PushBack(j);

      { 验证创建成功 }
      AssertEquals('容器应该包含正确数量的元素', 100, LVecDeques[i].Count);
    end;

    { 执行一些操作 }
    for var i := 0 to High(LVecDeques) do
    begin
      LVecDeques[i].Clear;
      LVecDeques[i].Reserve(200);

      for var j := 1 to 50 do
        LVecDeques[i].PushBack(j * 2);
    end;

    { 验证操作结果 }
    for var i := 0 to High(LVecDeques) do
    begin
      AssertEquals('操作后容器应该包含正确数量的元素', 50, LVecDeques[i].Count);
      AssertTrue('容量应该足够', LVecDeques[i].Capacity >= 50);
    end;

  finally
    { 清理所有容器 }
    for var i := 0 to High(LVecDeques) do
      if Assigned(LVecDeques[i]) then
        LVecDeques[i].Free;
  end;
end;

procedure TTestCase_VecDeque.Test_Regression_Performance;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LStartTime, LEndTime: TDateTime;
begin
  { 测试 Regression_Performance - 验证性能回归修复 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 预留足够容量以避免重分配影响性能测试 }
    LVecDeque.Reserve(50000);

    { 测试后端推入性能 }
    LStartTime := Now;
    for var i := 1 to 50000 do
      LVecDeque.PushBack(i);
    LEndTime := Now;

    var LPushBackMs := MilliSecondsBetween(LEndTime, LStartTime);
    AssertTrue('后端推入性能应该在合理范围内', LPushBackMs < 1000);

    { 测试随机访问性能 }
    LStartTime := Now;
    for var i := 1 to 10000 do
    begin
      var LIndex := Random(LVecDeque.Count);
      var LValue := LVecDeque.Get(LIndex);
    end;
    LEndTime := Now;

    var LAccessMs := MilliSecondsBetween(LEndTime, LStartTime);
    AssertTrue('随机访问性能应该在合理范围内', LAccessMs < 500);

    { 验证数据正确性 }
    AssertEquals('性能测试后元素数量应该正确', 50000, LVecDeque.Count);
    AssertEquals('第一个元素应该正确', 1, LVecDeque.Get(0));
    AssertEquals('最后一个元素应该正确', 50000, LVecDeque.Get(49999));
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_Regression_Compatibility;
var
  LVecDeque: specialize TVecDeque<Integer>;
begin
  { 测试 Regression_Compatibility - 验证向后兼容性 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 测试旧版本API的兼容性 }

    { 基础操作兼容性 }
    LVecDeque.Add(10); { IGenericCollection接口 }
    LVecDeque.PushBack(20); { 专用接口 }
    AssertEquals('兼容性测试后元素数量应该正确', 2, LVecDeque.Count);

    { 队列接口兼容性 }
    LVecDeque.Enqueue(30); { IQueue接口 }
    AssertEquals('队列接口兼容性测试后元素数量应该正确', 3, LVecDeque.Count);

    var LValue := LVecDeque.Dequeue; { IQueue接口 }
    AssertEquals('队列出队应该返回正确值', 10, LValue);
    AssertEquals('队列出队后元素数量应该正确', 2, LVecDeque.Count);

    { 双端队列接口兼容性 }
    LVecDeque.PushFront(5); { IDeque接口 }
    AssertEquals('双端队列接口兼容性测试后元素数量应该正确', 3, LVecDeque.Count);
    AssertEquals('前端元素应该正确', 5, LVecDeque.Front);

    { 集合接口兼容性 }
    var LContains := LVecDeque.Contains(20); { IGenericCollection接口 }
    AssertTrue('集合接口应该正确检测包含关系', LContains);

    var LRemoved := LVecDeque.Remove(20); { IGenericCollection接口 }
    AssertTrue('集合接口应该正确移除元素', LRemoved);
    AssertEquals('移除后元素数量应该正确', 2, LVecDeque.Count);
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_Regression_Edge_Case;
var
  LVecDeque: specialize TVecDeque<Integer>;
begin
  { 测试 Regression_Edge_Case - 边界情况回归测试 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 测试单元素容器的各种操作 }
    LVecDeque.PushBack(42);
    AssertEquals('单元素容器计数应该为1', 1, LVecDeque.Count);
    AssertEquals('单元素容器前端和后端应该相同', LVecDeque.Front, LVecDeque.Back);

    { 测试单元素容器的弹出 }
    var LValue := LVecDeque.PopBack;
    AssertEquals('弹出的值应该正确', 42, LValue);
    AssertTrue('弹出后应该为空', LVecDeque.IsEmpty);

    { 测试零容量调整 }
    LVecDeque.Resize(0);
    AssertEquals('调整为零大小后计数应该为0', 0, LVecDeque.Count);
    AssertTrue('调整为零大小后应该为空', LVecDeque.IsEmpty);

    { 测试从零开始的操作 }
    LVecDeque.PushFront(100);
    AssertEquals('从零开始前端推入后计数应该为1', 1, LVecDeque.Count);
    AssertEquals('从零开始前端推入的值应该正确', 100, LVecDeque.Get(0));

    { 测试边界索引操作 }
    LVecDeque.Set(0, 200);
    AssertEquals('边界索引设置应该正确', 200, LVecDeque.Get(0));
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_Regression_Concurrency;
var
  LVecDeque: specialize TVecDeque<Integer>;
begin
  { 测试 Regression_Concurrency - 并发安全回归测试 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 注意：这是单线程模拟并发场景的测试 }
    { 在实际多线程环境中，需要适当的同步机制 }

    { 模拟并发添加操作 }
    for var i := 1 to 1000 do
    begin
      if i mod 2 = 0 then
        LVecDeque.PushBack(i)
      else
        LVecDeque.PushFront(i);
    end;

    AssertEquals('模拟并发添加后元素数量应该正确', 1000, LVecDeque.Count);

    { 模拟并发读取操作 }
    var LSum := 0;
    for var i := 0 to LVecDeque.Count - 1 do
      LSum := LSum + LVecDeque.Get(i);

    { 验证数据完整性 }
    var LExpectedSum := (1 + 1000) * 1000 div 2; { 1到1000的和 }
    AssertEquals('并发操作后数据完整性应该保持', LExpectedSum, LSum);

    { 模拟并发移除操作 }
    for var i := 1 to 500 do
    begin
      if not LVecDeque.IsEmpty then
      begin
        if i mod 2 = 0 then
          LVecDeque.PopBack
        else
          LVecDeque.PopFront;
      end;
    end;

    AssertEquals('模拟并发移除后元素数量应该正确', 500, LVecDeque.Count);
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_Regression_Serialization;
var
  LVecDeque1, LVecDeque2: specialize TVecDeque<Integer>;
begin
  { 测试 Regression_Serialization - 序列化兼容性回归测试 }
  LVecDeque1 := specialize TVecDeque<Integer>.Create;
  LVecDeque2 := specialize TVecDeque<Integer>.Create;
  try
    { 准备测试数据 }
    for var i := 1 to 20 do
      LVecDeque1.PushBack(i * i); { 平方数序列 }

    { 模拟序列化过程 - 复制数据 }
    for var i := 0 to LVecDeque1.Count - 1 do
      LVecDeque2.PushBack(LVecDeque1.Get(i));

    { 验证序列化结果 }
    AssertEquals('序列化后元素数量应该相同', LVecDeque1.Count, LVecDeque2.Count);

    for var i := 0 to LVecDeque1.Count - 1 do
      AssertEquals('序列化后元素值应该相同', LVecDeque1.Get(i), LVecDeque2.Get(i));

    { 验证序列化后的独立性 }
    LVecDeque1.PushBack(999);
    AssertTrue('序列化后的容器应该独立', LVecDeque1.Count <> LVecDeque2.Count);

    LVecDeque2.PushBack(888);
    AssertTrue('序列化后的容器应该独立操作',
               LVecDeque1.Get(LVecDeque1.Count - 1) <> LVecDeque2.Get(LVecDeque2.Count - 1));
  finally
    LVecDeque1.Free;
    LVecDeque2.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_Regression_Integration;
var
  LVecDeque: specialize TVecDeque<Integer>;
begin
  { 测试 Regression_Integration - 集成测试回归 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 综合测试各种操作的组合 }

    { 阶段1：构建阶段 }
    LVecDeque.Reserve(100);
    for var i := 1 to 50 do
    begin
      LVecDeque.PushBack(i);
      if i mod 10 = 0 then
        LVecDeque.PushFront(-i);
    end;

    AssertEquals('构建阶段后元素数量应该正确', 55, LVecDeque.Count);

    { 阶段2：操作阶段 }
    for var i := 1 to 10 do
    begin
      if LVecDeque.Contains(i * 5) then
        LVecDeque.Remove(i * 5);
    end;

    { 阶段3：重组阶段 }
    LVecDeque.ShrinkToFit;
    var LMidIndex := LVecDeque.Count div 2;
    for var i := 0 to LMidIndex - 1 do
    begin
      var LTemp := LVecDeque.Get(i);
      LVecDeque.Set(i, LVecDeque.Get(LVecDeque.Count - 1 - i));
      LVecDeque.Set(LVecDeque.Count - 1 - i, LTemp);
    end;

    { 阶段4：验证阶段 }
    AssertTrue('集成测试后容器应该仍然有效', LVecDeque.Count > 0);
    AssertTrue('集成测试后容量应该合理', LVecDeque.Capacity >= LVecDeque.Count);

    { 验证基本操作仍然正常 }
    var LOriginalCount := LVecDeque.Count;
    LVecDeque.PushBack(9999);
    AssertEquals('集成测试后基本操作应该正常', LOriginalCount + 1, LVecDeque.Count);
    AssertEquals('集成测试后新添加的元素应该正确', 9999, LVecDeque.Back);
  finally
    LVecDeque.Free;
  end;
end;

{ ===== 专用功能测试系列实现 ===== }

procedure TTestCase_VecDeque.Test_Specialized_Circular_Buffer;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LBufferSize: SizeUInt;
begin
  { 测试 Specialized_Circular_Buffer - 循环缓冲区模拟 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    LBufferSize := 10;

    { 模拟循环缓冲区行为 }
    for var i := 1 to 25 do
    begin
      LVecDeque.PushBack(i);

      { 保持固定大小 }
      if LVecDeque.Count > LBufferSize then
        LVecDeque.PopFront;
    end;

    { 验证循环缓冲区状态 }
    AssertEquals('循环缓冲区大小应该固定', LBufferSize, LVecDeque.Count);
    AssertEquals('循环缓冲区应该包含最新数据', 16, LVecDeque.Front);
    AssertEquals('循环缓冲区应该包含最新数据', 25, LVecDeque.Back);

    { 验证数据连续性 }
    for var i := 0 to LVecDeque.Count - 1 do
      AssertEquals('循环缓冲区数据应该连续', 16 + i, LVecDeque.Get(i));
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_Specialized_Stack_Simulation;
var
  LVecDeque: specialize TVecDeque<Integer>;
begin
  { 测试 Specialized_Stack_Simulation - 栈模拟 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 使用VecDeque模拟栈操作 }

    { 压栈操作 (使用后端) }
    for var i := 1 to 10 do
      LVecDeque.PushBack(i); { 相当于Push }

    AssertEquals('压栈后栈大小应该正确', 10, LVecDeque.Count);
    AssertEquals('栈顶元素应该正确', 10, LVecDeque.Back); { 相当于Top }

    { 弹栈操作 }
    var LPoppedValues: array[0..4] of Integer;
    for var i := 0 to High(LPoppedValues) do
      LPoppedValues[i] := LVecDeque.PopBack; { 相当于Pop }

    { 验证弹栈结果 (LIFO) }
    for var i := 0 to High(LPoppedValues) do
      AssertEquals('弹栈顺序应该正确', 10 - i, LPoppedValues[i]);

    AssertEquals('弹栈后栈大小应该正确', 5, LVecDeque.Count);
    AssertEquals('弹栈后栈顶应该正确', 5, LVecDeque.Back);
  finally
    LVecDeque.Free;
  end;
end;

{ ===== 剩余构造函数测试完成 ===== }

procedure TTestCase_VecDeque.Test_Create_Capacity_GrowStrategy;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LInitialCapacity: SizeUInt;
  LGrowStrategy: TGrowStrategy;
begin
  { 测试 Create_Capacity_GrowStrategy - 使用容量和增长策略的构造函数 }
  LInitialCapacity := 16;
  LGrowStrategy := gsDouble;
  LVecDeque := specialize TVecDeque<Integer>.Create(LInitialCapacity, LGrowStrategy);
  try
    AssertNotNull('使用容量和增长策略创建的VecDeque应该有效', LVecDeque);
    AssertEquals('初始元素数量应该为0', 0, LVecDeque.Count);
    AssertTrue('容量应该至少为指定值', LVecDeque.Capacity >= LInitialCapacity);

    { 测试增长策略效果 }
    var LOriginalCapacity := LVecDeque.Capacity;
    for var i := 1 to Integer(LInitialCapacity) + 5 do
      LVecDeque.PushBack(i);

    AssertTrue('超过初始容量后应该按策略增长', LVecDeque.Capacity > LOriginalCapacity);
    AssertEquals('元素数量应该正确', LInitialCapacity + 5, LVecDeque.Count);
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_Create_Capacity_GrowStrategy_Data;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LInitialCapacity: SizeUInt;
  LGrowStrategy: TGrowStrategy;
  LData: Pointer;
begin
  { 测试 Create_Capacity_GrowStrategy_Data - 使用容量、增长策略和数据的构造函数 }
  LInitialCapacity := 32;
  LGrowStrategy := gsLinear;
  LData := @Self;
  LVecDeque := specialize TVecDeque<Integer>.Create(LInitialCapacity, LGrowStrategy, LData);
  try
    AssertNotNull('使用容量、增长策略和数据创建的VecDeque应该有效', LVecDeque);
    AssertEquals('初始元素数量应该为0', 0, LVecDeque.Count);
    AssertTrue('容量应该至少为指定值', LVecDeque.Capacity >= LInitialCapacity);

    { 测试基本操作 }
    for var i := 1 to 10 do
      LVecDeque.PushBack(i * 3);

    AssertEquals('添加元素后数量应该正确', 10, LVecDeque.Count);
    for var i := 0 to 9 do
      AssertEquals('元素值应该正确', (i + 1) * 3, LVecDeque.Get(i));
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_Create_Array;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LArray: array[0..4] of Integer;
begin
  { 测试 Create_Array - 使用数组初始化的构造函数 }
  for var i := 0 to High(LArray) do
    LArray[i] := (i + 1) * 10;

  LVecDeque := specialize TVecDeque<Integer>.Create(LArray);
  try
    AssertNotNull('使用数组创建的VecDeque应该有效', LVecDeque);
    AssertEquals('初始元素数量应该等于数组长度', Length(LArray), LVecDeque.Count);

    { 验证数组内容被正确复制 }
    for var i := 0 to High(LArray) do
      AssertEquals('数组元素应该被正确复制', LArray[i], LVecDeque.Get(i));

    { 验证独立性 - 修改原数组不影响VecDeque }
    LArray[0] := 999;
    AssertEquals('修改原数组不应该影响VecDeque', 10, LVecDeque.Get(0));
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_Create_Array_Allocator;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LArray: array[0..3] of Integer;
  LAllocator: IAllocator;
begin
  { 测试 Create_Array_Allocator - 使用数组和分配器的构造函数 }
  for var i := 0 to High(LArray) do
    LArray[i] := (i + 1) * 7;

  LAllocator := TDefaultAllocator.Create;
  LVecDeque := specialize TVecDeque<Integer>.Create(LArray, LAllocator);
  try
    AssertNotNull('使用数组和分配器创建的VecDeque应该有效', LVecDeque);
    AssertEquals('初始元素数量应该等于数组长度', Length(LArray), LVecDeque.Count);

    { 验证数组内容 }
    for var i := 0 to High(LArray) do
      AssertEquals('数组元素应该被正确复制', LArray[i], LVecDeque.Get(i));

    { 测试后续操作 }
    LVecDeque.PushBack(100);
    AssertEquals('添加元素后数量应该正确', Length(LArray) + 1, LVecDeque.Count);
    AssertEquals('新添加的元素应该正确', 100, LVecDeque.Get(Length(LArray)));
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_Create_Collection;
var
  LVecDeque1, LVecDeque2: specialize TVecDeque<Integer>;
begin
  { 测试 Create_Collection - 使用另一个集合初始化的构造函数 }
  LVecDeque1 := specialize TVecDeque<Integer>.Create;
  try
    { 准备源集合 }
    for var i := 1 to 8 do
      LVecDeque1.PushBack(i * i); { 平方数 }

    { 使用源集合创建新集合 }
    LVecDeque2 := specialize TVecDeque<Integer>.Create(LVecDeque1);
    try
      AssertNotNull('使用集合创建的VecDeque应该有效', LVecDeque2);
      AssertEquals('新集合元素数量应该等于源集合', LVecDeque1.Count, LVecDeque2.Count);

      { 验证内容被正确复制 }
      for var i := 0 to LVecDeque1.Count - 1 do
        AssertEquals('集合元素应该被正确复制', LVecDeque1.Get(i), LVecDeque2.Get(i));

      { 验证独立性 }
      LVecDeque1.PushBack(999);
      AssertTrue('修改源集合不应该影响新集合', LVecDeque1.Count <> LVecDeque2.Count);

      LVecDeque2.PushBack(888);
      AssertTrue('修改新集合不应该影响源集合',
                 LVecDeque1.Get(LVecDeque1.Count - 1) <> LVecDeque2.Get(LVecDeque2.Count - 1));
    finally
      LVecDeque2.Free;
    end;
  finally
    LVecDeque1.Free;
  end;
end;

{ ===== 剩余基础接口测试完成 ===== }

procedure TTestCase_VecDeque.Test_IEnumerable_GetEnumerator;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LEnumerator: IEnumerator<Integer>;
  LSum, LCount: Integer;
begin
  { 测试 IEnumerable_GetEnumerator - 枚举器接口 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 准备测试数据 }
    for var i := 1 to 5 do
      LVecDeque.PushBack(i * 2);

    { 获取枚举器 }
    LEnumerator := LVecDeque.GetEnumerator;
    AssertNotNull('枚举器应该有效', LEnumerator);

    { 使用枚举器遍历 }
    LSum := 0;
    LCount := 0;
    while LEnumerator.MoveNext do
    begin
      LSum := LSum + LEnumerator.Current;
      Inc(LCount);
    end;

    { 验证枚举结果 }
    AssertEquals('枚举的元素数量应该正确', 5, LCount);
    AssertEquals('枚举的元素总和应该正确', 30, LSum); { 2+4+6+8+10 = 30 }
  finally
    LVecDeque.Free;
  end;
end;

