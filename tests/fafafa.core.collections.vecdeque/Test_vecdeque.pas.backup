      LVecDeque2.Free;
    end;
  finally
    LVecDeque1.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_Create_Collection_Allocator_GrowStrategy;
var
  LVecDeque1, LVecDeque2: specialize TVecDeque<Integer>;
  LAllocator: IAllocator;
  LGrowStrategy: TGrowStrategy;
begin
  { 测试 Create_Collection_Allocator_GrowStrategy - 使用集合、分配器和增长策略的构造函数 }
  LVecDeque1 := specialize TVecDeque<Integer>.Create;
  try
    { 准备源集合 }
    for var i := 1 to 5 do
      LVecDeque1.PushBack(i * 7);

    { 使用源集合、分配器和增长策略创建新集合 }
    LAllocator := TDefaultAllocator.Create;
    LGrowStrategy := gsDouble;
    LVecDeque2 := specialize TVecDeque<Integer>.Create(LVecDeque1, LAllocator, LGrowStrategy);
    try
      AssertNotNull('使用集合、分配器和增长策略创建的VecDeque应该有效', LVecDeque2);
      AssertEquals('新集合元素数量应该等于源集合', LVecDeque1.Count, LVecDeque2.Count);

      { 验证内容被正确复制 }
      for var i := 0 to LVecDeque1.Count - 1 do
        AssertEquals('集合元素应该被正确复制', LVecDeque1.Get(i), LVecDeque2.Get(i));

      { 测试增长策略 }
      var LOriginalCapacity := LVecDeque2.Capacity;
      for var i := 1 to 10 do
        LVecDeque2.PushBack(i * 100);
      AssertTrue('增长策略应该生效', LVecDeque2.Capacity > LOriginalCapacity);
    finally
      LVecDeque2.Free;
    end;
  finally
    LVecDeque1.Free;
  end;
end;

