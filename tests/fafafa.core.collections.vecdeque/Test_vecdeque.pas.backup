{ FindUnChecked 系列测试实现 }

procedure TTestCase_VecDeque.Test_FindUnChecked_Element;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LIndex: SizeUInt;
begin
  { 测试 FindUnChecked_Element - 不检查边界的元素查找 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 准备测试数据 }
    LVecDeque.PushBack(10);
    LVecDeque.PushBack(20);
    LVecDeque.PushBack(30);
    LVecDeque.PushBack(20);
    LVecDeque.PushBack(40);

    { 查找存在的元素 }
    LIndex := LVecDeque.FindUnChecked(20);
    AssertEquals('应该找到第一个匹配元素的索引', SizeUInt(1), LIndex);

    { 查找第一个元素 }
    LIndex := LVecDeque.FindUnChecked(10);
    AssertEquals('应该找到第一个元素', SizeUInt(0), LIndex);

    { 查找最后一个元素 }
    LIndex := LVecDeque.FindUnChecked(40);
    AssertEquals('应该找到最后一个元素', SizeUInt(4), LIndex);

    { 查找不存在的元素 }
    LIndex := LVecDeque.FindUnChecked(99);
    AssertEquals('不存在的元素应该返回SIZE_MAX', SIZE_MAX, LIndex);
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_FindUnChecked_Element_Func;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LIndex: SizeUInt;
begin
  { 测试 FindUnChecked_Element_Func - 不检查边界使用函数指针查找元素 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
