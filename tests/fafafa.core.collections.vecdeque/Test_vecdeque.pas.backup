procedure TTestCase_VecDeque.Test_Specialized_Priority_Queue;
var
  LVecDeque: specialize TVecDeque<Integer>;
begin
  { 测试 Specialized_Priority_Queue - 优先队列模拟 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 模拟优先队列行为 - 使用排序维护优先级 }

    { 插入元素并保持排序 }
    var LValues: array[0..6] of Integer = (15, 3, 9, 21, 6, 12, 18);
    for var i := 0 to High(LValues) do
    begin
      { 找到插入位置 }
      var LInsertPos := LVecDeque.BinarySearchInsert(LValues[i]);
      LVecDeque.Insert(LInsertPos, LValues[i]);
    end;

    { 验证优先队列状态 }
    AssertEquals('优先队列元素数量应该正确', Length(LValues), LVecDeque.Count);

    { 验证排序顺序 }
    for var i := 0 to LVecDeque.Count - 2 do
      AssertTrue('优先队列应该保持排序', LVecDeque.Get(i) <= LVecDeque.Get(i + 1));

    { 模拟优先级出队 (取最小值) }
    var LMinValue := LVecDeque.PopFront;
    AssertEquals('应该取出最小值', 3, LMinValue);

    { 模拟优先级出队 (取最大值) }
    var LMaxValue := LVecDeque.PopBack;
    AssertEquals('应该取出最大值', 21, LMaxValue);

    AssertEquals('出队后元素数量应该正确', Length(LValues) - 2, LVecDeque.Count);
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_Specialized_Sliding_Window;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LWindowSize: SizeUInt;
  LDataStream: array[0..19] of Integer;
begin
  { 测试 Specialized_Sliding_Window - 滑动窗口模拟 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    LWindowSize := 5;

    { 准备数据流 }
    for var i := 0 to High(LDataStream) do
      LDataStream[i] := (i + 1) * 2;

    { 模拟滑动窗口处理 }
    for var i := 0 to High(LDataStream) do
    begin
      { 添加新数据 }
      LVecDeque.PushBack(LDataStream[i]);

      { 维护窗口大小 }
      if LVecDeque.Count > LWindowSize then
        LVecDeque.PopFront;

      { 验证窗口状态 }
      AssertTrue('窗口大小不应该超过限制', LVecDeque.Count <= LWindowSize);

      { 在窗口填满后验证内容 }
      if LVecDeque.Count = LWindowSize then
      begin
        var LExpectedStart := Max(0, Integer(i) - Integer(LWindowSize) + 1);
        for var j := 0 to LVecDeque.Count - 1 do
        begin
          var LExpectedValue := (LExpectedStart + j + 1) * 2;
          AssertEquals('滑动窗口内容应该正确', LExpectedValue, LVecDeque.Get(j));
        end;
      end;
    end;

    { 最终验证 }
    AssertEquals('最终窗口大小应该正确', LWindowSize, LVecDeque.Count);
    AssertEquals('窗口应该包含最新数据', 40, LVecDeque.Back); { 20*2 }
    AssertEquals('窗口应该包含最新数据', 32, LVecDeque.Front); { 16*2 }
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_Specialized_Undo_Redo;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LCurrentState: Integer;
  LMaxHistory: SizeUInt;
begin
  { 测试 Specialized_Undo_Redo - 撤销重做功能模拟 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    LCurrentState := 0;
    LMaxHistory := 10;

    { 模拟状态变化和历史记录 }
    for var i := 1 to 15 do
    begin
      { 记录当前状态 }
      LVecDeque.PushBack(LCurrentState);

      { 限制历史记录大小 }
      if LVecDeque.Count > LMaxHistory then
        LVecDeque.PopFront;

      { 更新状态 }
      LCurrentState := LCurrentState + i;
    end;

    { 验证历史记录 }
    AssertEquals('历史记录大小应该受限', LMaxHistory, LVecDeque.Count);

    { 模拟撤销操作 }
    var LUndoCount := 3;
    for var i := 1 to LUndoCount do
    begin
      if not LVecDeque.IsEmpty then
      begin
        LCurrentState := LVecDeque.PopBack;
      end;
    end;

    { 验证撤销结果 }
    AssertEquals('撤销后历史记录数量应该正确', LMaxHistory - LUndoCount, LVecDeque.Count);

    { 模拟重做操作 - 重新执行一些操作 }
    for var i := 1 to 2 do
    begin
      LVecDeque.PushBack(LCurrentState);
      LCurrentState := LCurrentState + 100 + i;
    end;

    { 验证重做结果 }
    AssertEquals('重做后历史记录数量应该正确', LMaxHistory - LUndoCount + 2, LVecDeque.Count);
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_Specialized_Message_Queue;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LMessageId: Integer;
begin
  { 测试 Specialized_Message_Queue - 消息队列模拟 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    LMessageId := 1000;

    { 模拟消息入队 }
    for var i := 1 to 10 do
    begin
      LVecDeque.Enqueue(LMessageId + i); { 使用队列接口 }
    end;

    AssertEquals('消息队列应该包含所有消息', 10, LVecDeque.Count);

    { 模拟优先消息插入 (紧急消息插到前面) }
    var LUrgentMessage := 9999;
    LVecDeque.PushFront(LUrgentMessage);
    AssertEquals('紧急消息插入后数量应该正确', 11, LVecDeque.Count);
    AssertEquals('紧急消息应该在队首', LUrgentMessage, LVecDeque.Front);

    { 模拟消息处理 }
    var LProcessedMessages: array[0..4] of Integer;
    for var i := 0 to High(LProcessedMessages) do
    begin
      LProcessedMessages[i] := LVecDeque.Dequeue; { 使用队列接口 }
    end;

    { 验证消息处理顺序 }
    AssertEquals('第一个处理的应该是紧急消息', LUrgentMessage, LProcessedMessages[0]);
    for var i := 1 to High(LProcessedMessages) do
    begin
      var LExpectedMessage := LMessageId + i;
      AssertEquals('消息处理顺序应该正确', LExpectedMessage, LProcessedMessages[i]);
    end;

    AssertEquals('处理后剩余消息数量应该正确', 6, LVecDeque.Count);

    { 模拟批量消息清理 }
    LVecDeque.Clear;
    AssertEquals('清理后消息队列应该为空', 0, LVecDeque.Count);
    AssertTrue('清理后消息队列应该为空状态', LVecDeque.IsEmpty);
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_Specialized_Data_Pipeline;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LBatchSize: SizeUInt;
begin
  { 测试 Specialized_Data_Pipeline - 数据管道模拟 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    LBatchSize := 5;

    { 模拟数据流入管道 }
    for var i := 1 to 23 do
    begin
      LVecDeque.PushBack(i);

      { 当达到批处理大小时，处理一批数据 }
      if LVecDeque.Count >= LBatchSize then
      begin
        { 模拟批处理 - 处理前面的数据 }
        var LBatchSum := 0;
        for var j := 0 to Integer(LBatchSize) - 1 do
        begin
          LBatchSum := LBatchSum + LVecDeque.PopFront;
        end;

        { 验证批处理结果 }
        AssertTrue('批处理结果应该合理', LBatchSum > 0);
      end;
    end;

    { 处理剩余数据 }
    var LRemainingCount := LVecDeque.Count;
    AssertTrue('应该有剩余数据', LRemainingCount > 0);
    AssertTrue('剩余数据应该少于批大小', LRemainingCount < LBatchSize);

    { 验证剩余数据的正确性 }
    var LExpectedStart := 23 - Integer(LRemainingCount) + 1;
    for var i := 0 to LVecDeque.Count - 1 do
    begin
      AssertEquals('剩余数据应该正确', LExpectedStart + i, LVecDeque.Get(i));
    end;
  finally
    LVecDeque.Free;
  end;
end;

{ ===== 最终完整性验证测试 ===== }

procedure TTestCase_VecDeque.Test_Final_Comprehensive_Integration;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LStartTime, LEndTime: TDateTime;
begin
  { 测试 Final_Comprehensive_Integration - 最终综合集成测试 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    LStartTime := Now;

    { 第一阶段：大规模数据操作 }
    LVecDeque.Reserve(10000);
    for var i := 1 to 5000 do
    begin
      LVecDeque.PushBack(i);
      if i mod 100 = 0 then
        LVecDeque.PushFront(-i);
    end;

    { 第二阶段：复杂查找和替换 }
    for var i := 1 to 50 do
    begin
      if LVecDeque.Contains(i * 10) then
        LVecDeque.Replace(i * 10, i * 100);
    end;

    { 第三阶段：排序和二分查找 }
    LVecDeque.Sort;
    AssertTrue('排序后应该有序', LVecDeque.IsSorted);

    var LSearchValue := 1000;
    var LFoundIndex := LVecDeque.BinarySearch(LSearchValue);
    if LFoundIndex <> SIZE_MAX then
      AssertEquals('二分查找结果应该正确', LSearchValue, LVecDeque.Get(LFoundIndex));

    { 第四阶段：批量操作 }
    LVecDeque.FillWith(999, 100);
    LVecDeque.Shuffle;

    { 第五阶段：内存管理 }
    LVecDeque.ShrinkToFit;
    var LCapacityAfterShrink := LVecDeque.Capacity;
    AssertTrue('收缩后容量应该合理', LCapacityAfterShrink >= LVecDeque.Count);

    { 第六阶段：接口兼容性 }
    var LAsQueue := LVecDeque as IQueue<Integer>;
    LAsQueue.Enqueue(88888);
    var LDequeuedValue := LAsQueue.Dequeue;

    var LAsDeque := LVecDeque as IDeque<Integer>;
    LAsDeque.PushFront(77777);
    var LFrontValue := LAsDeque.PopFront;
    AssertEquals('接口操作应该正确', 77777, LFrontValue);

    LEndTime := Now;
    var LElapsedMs := MilliSecondsBetween(LEndTime, LStartTime);

    { 最终验证 }
    AssertTrue('综合测试应该在合理时间内完成', LElapsedMs < 10000); { 10秒内 }
    AssertTrue('综合测试后容器应该仍然有效', LVecDeque.Count > 0);
    AssertTrue('综合测试后容量应该合理', LVecDeque.Capacity >= LVecDeque.Count);

    { 数据完整性最终检查 }
    for var i := 0 to Min(99, LVecDeque.Count - 1) do
    begin
      var LValue := LVecDeque.Get(i);
      { 值应该在合理范围内 }
      AssertTrue('最终数据应该在合理范围内', (LValue >= -5000) and (LValue <= 100000));
    end;
  finally
    LVecDeque.Free;
  end;
end;

{ ===== 剩余构造函数测试完成 ===== }

procedure TTestCase_VecDeque.Test_Create_Collection_Allocator;
var
  LVecDeque1, LVecDeque2: specialize TVecDeque<Integer>;
  LAllocator: IAllocator;
begin
  { 测试 Create_Collection_Allocator - 使用集合和分配器的构造函数 }
  LVecDeque1 := specialize TVecDeque<Integer>.Create;
  try
    { 准备源集合 }
    for var i := 1 to 6 do
      LVecDeque1.PushBack(i * 3);

    { 使用源集合和分配器创建新集合 }
    LAllocator := TDefaultAllocator.Create;
    LVecDeque2 := specialize TVecDeque<Integer>.Create(LVecDeque1, LAllocator);
    try
      AssertNotNull('使用集合和分配器创建的VecDeque应该有效', LVecDeque2);
      AssertEquals('新集合元素数量应该等于源集合', LVecDeque1.Count, LVecDeque2.Count);

      { 验证内容被正确复制 }
      for var i := 0 to LVecDeque1.Count - 1 do
        AssertEquals('集合元素应该被正确复制', LVecDeque1.Get(i), LVecDeque2.Get(i));

      { 验证独立性 }
      LVecDeque1.PushBack(999);
      AssertTrue('修改源集合不应该影响新集合', LVecDeque1.Count <> LVecDeque2.Count);
    finally
      LVecDeque2.Free;
    end;
  finally
    LVecDeque1.Free;
  end;
end;

