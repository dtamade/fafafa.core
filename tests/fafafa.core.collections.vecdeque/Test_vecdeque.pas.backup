procedure TTestCase_VecDeque.Test_CountIF_StartIndex_Func;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LCount: SizeUInt;
  LStartIndex: SizeUInt;
begin
  { 测试 CountIF_StartIndex_Func - 从指定索引开始使用函数指针统计满足条件的元素 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 准备测试数据 }
    LVecDeque.PushBack(1);  { 奇数 }
    LVecDeque.PushBack(2);  { 偶数 }
    LVecDeque.PushBack(3);  { 奇数 }
    LVecDeque.PushBack(4);  { 偶数 }
    LVecDeque.PushBack(5);  { 奇数 }
    LVecDeque.PushBack(6);  { 偶数 }

    LStartIndex := 2;

    { 从索引2开始统计偶数 }
    LCount := LVecDeque.CountIF(LStartIndex, @PredicateTestFunc, @Self);
    AssertEquals('应该从起始索引正确统计满足条件的元素数量', SizeUInt(2), LCount);

    { 从索引0开始统计（应该统计全部） }
    LCount := LVecDeque.CountIF(0, @PredicateTestFunc, @Self);
    AssertEquals('从索引0开始应该统计所有满足条件的元素', SizeUInt(3), LCount);

    { 从最后一个索引开始统计 }
    LCount := LVecDeque.CountIF(5, @PredicateTestFunc, @Self);
    AssertEquals('从最后索引开始应该只统计最后的元素', SizeUInt(1), LCount);
  finally
    LVecDeque.Free;
  end;
end;

