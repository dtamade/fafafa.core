{ ===== IArray<T> 接口方法扩展测试实现 ===== }

procedure TTestCase_VecDeque.Test_Fill;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LFillValue: Integer;
  LI: Integer;
begin
  { 测试 Fill - 填充整个容器 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 准备测试数据 }
    LVecDeque.Resize(5);
    LFillValue := 42;

    { 执行填充 }
    LVecDeque.Fill(LFillValue);

    { 验证结果 }
    AssertEquals('Count should remain same', 5, LVecDeque.Count);
    for LI := 0 to LVecDeque.Count - 1 do
      AssertEquals('All elements should be fill value', LFillValue, LVecDeque.Get(LI));
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_Fill_Index;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LFillValue: Integer;
  LStartIndex: SizeUInt;
  LI: Integer;
begin
  { 测试 Fill_Index - 从指定索引开始填充 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 准备测试数据 }
    for LI := 0 to 4 do
      LVecDeque.PushBack(LI);
    LFillValue := 99;
    LStartIndex := 2;

    { 执行填充 }
    LVecDeque.Fill(LFillValue, LStartIndex);

    { 验证结果 }
    AssertEquals('Count should remain same', 5, LVecDeque.Count);
    { 前面的元素应该保持不变 }
    for var i := 0 to Integer(LStartIndex) - 1 do
      AssertEquals('Element before start should be unchanged', i, LVecDeque.Get(i));
    { 后面的元素应该被填充 }
    for var i := Integer(LStartIndex) to LVecDeque.Count - 1 do
      AssertEquals('Element from start should be fill value', LFillValue, LVecDeque.Get(i));
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_Fill_Index_Count;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LFillValue: Integer;
  LStartIndex, LCount: SizeUInt;
begin
  { 测试 Fill_Index_Count - 在指定范围内填充 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 准备测试数据 }
    for var i := 0 to 6 do
      LVecDeque.PushBack(i);
    LFillValue := 77;
    LStartIndex := 2;
    LCount := 3;

    { 执行填充 }
    LVecDeque.Fill(LFillValue, LStartIndex, LCount);

    { 验证结果 }
    AssertEquals('Count should remain same', 7, LVecDeque.Count);
    { 前面的元素应该保持不变 }
    for var i := 0 to Integer(LStartIndex) - 1 do
      AssertEquals('Element before range should be unchanged', i, LVecDeque.Get(i));
    { 范围内的元素应该被填充 }
    for var i := Integer(LStartIndex) to Integer(LStartIndex + LCount) - 1 do
      AssertEquals('Element in range should be fill value', LFillValue, LVecDeque.Get(i));
    { 后面的元素应该保持不变 }
    for var i := Integer(LStartIndex + LCount) to LVecDeque.Count - 1 do
      AssertEquals('Element after range should be unchanged', i, LVecDeque.Get(i));
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_Zero;
var
  LVecDeque: specialize TVecDeque<Integer>;
begin
  { 测试 Zero - 将整个容器清零 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 准备测试数据 }
    for var i := 1 to 5 do
      LVecDeque.PushBack(i * 10);

