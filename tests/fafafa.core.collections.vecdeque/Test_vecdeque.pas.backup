    AssertEquals('前面的元素应该保持不变', 2, LVecDeque1.Get(1));
    AssertEquals('写入的第一个元素应该正确', 100, LVecDeque1.Get(2));
    AssertEquals('写入的第二个元素应该正确', 200, LVecDeque1.Get(3));
    AssertEquals('写入的第三个元素应该正确', 300, LVecDeque1.Get(4));
    AssertEquals('后面的元素应该保持不变', 6, LVecDeque1.Get(5));
  finally
    LVecDeque1.Free;
    LVecDeque2.Free;
  end;
end;

