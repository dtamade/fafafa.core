procedure TTestCase_VecDeque.Test_GetEnumerator;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LEnumerator: specialize IEnumerator<Integer>;
  LCount: Integer;
  LExpectedValue: Integer;
begin
  { 测试 GetEnumerator - 获取枚举器 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 测试空集合的枚举器 }
    LEnumerator := LVecDeque.GetEnumerator as specialize IEnumerator<Integer>;
    AssertNotNull('GetEnumerator should return valid enumerator', LEnumerator);
    AssertFalse('Empty collection enumerator should not have current', LEnumerator.MoveNext);

    { 添加一些元素 }
    LVecDeque.PushBack(10);
    LVecDeque.PushBack(20);
    LVecDeque.PushBack(30);

    { 测试枚举器遍历 }
    LEnumerator := LVecDeque.GetEnumerator as specialize IEnumerator<Integer>;
    LCount := 0;
    LExpectedValue := 10;
    while LEnumerator.MoveNext do
    begin
      AssertEquals('Enumerator current should match expected', LExpectedValue, LEnumerator.Current);
      Inc(LCount);
      Inc(LExpectedValue, 10);
    end;
    AssertEquals('Should enumerate all elements', 3, LCount);
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_Iter;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LIter: specialize TIter<Integer>;
  LCount: Integer;
begin
  { 测试 Iter - 获取迭代器 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 添加测试数据 }
    LVecDeque.PushBack(5);
    LVecDeque.PushBack(15);
    LVecDeque.PushBack(25);

    { 获取迭代器并测试 }
    LIter := LVecDeque.Iter;
    AssertNotNull('Iter should return valid iterator', LIter);

    { 测试迭代器功能 }
    LCount := 0;
    while LIter.HasNext do
    begin
      case LCount of
        0: AssertEquals('First element should be 5', 5, LIter.Next);
        1: AssertEquals('Second element should be 15', 15, LIter.Next);
        2: AssertEquals('Third element should be 25', 25, LIter.Next);
      end;
      Inc(LCount);
    end;
    AssertEquals('Should iterate through all elements', 3, LCount);
  finally
    LVecDeque.Free;
  end;
end;

