{ Shuffle 系列测试实现 }

procedure TTestCase_VecDeque.Test_Shuffle;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LOriginalElements: array[0..4] of Integer;
  LShuffled: Boolean;
begin
  { 测试 Shuffle - 随机打乱所有元素 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 准备测试数据 }
    for var i := 0 to High(LOriginalElements) do
    begin
      LOriginalElements[i] := i + 1;
      LVecDeque.PushBack(LOriginalElements[i]);
    end;

    { 执行打乱 }
    LVecDeque.Shuffle;

    { 验证结果 }
    AssertEquals('Count should remain same', Length(LOriginalElements), LVecDeque.Count);

    { 验证所有原始元素仍然存在 }
    for var i := 0 to High(LOriginalElements) do
    begin
      var LFound := False;
      for var j := 0 to LVecDeque.Count - 1 do
      begin
        if LVecDeque.Get(j) = LOriginalElements[i] then
        begin
          LFound := True;
          Break;
        end;
      end;
      AssertTrue('Original element should still exist after shuffle', LFound);
    end;

    { 检查是否真的被打乱了（至少有一个元素位置改变） }
    LShuffled := False;
    for var i := 0 to LVecDeque.Count - 1 do
    begin
      if LVecDeque.Get(i) <> LOriginalElements[i] then
      begin
        LShuffled := True;
        Break;
      end;
    end;
    { 注意：理论上有很小概率打乱后顺序不变，但对于5个元素来说概率很低 }
    AssertTrue('Elements should likely be shuffled', LShuffled);
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_Shuffle_StartIndex;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LStartIndex: SizeUInt;
begin
  { 测试 Shuffle_StartIndex - 从指定索引开始打乱 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 准备测试数据 }
    for var i := 1 to 8 do
      LVecDeque.PushBack(i);

    LStartIndex := 3;

    { 执行从索引3开始的打乱 }
    LVecDeque.Shuffle(LStartIndex);

    { 验证结果 }
    AssertEquals('Count should remain same', 8, LVecDeque.Count);

    { 前面的元素应该保持不变 }
    for var i := 0 to Integer(LStartIndex) - 1 do
      AssertEquals('Element before start index should be unchanged', i + 1, LVecDeque.Get(i));

    { 后面的元素应该仍然存在（但可能顺序改变） }
    for var i := Integer(LStartIndex) + 1 to 8 do
    begin
      var LFound := False;
      for var j := Integer(LStartIndex) to LVecDeque.Count - 1 do
      begin
        if LVecDeque.Get(j) = i then
        begin
          LFound := True;
          Break;
        end;
      end;
      AssertTrue('Element should still exist in shuffled range', LFound);
    end;
  finally
    LVecDeque.Free;
  end;
end;

{ 完成剩余的CountOf系列测试实现 }

procedure TTestCase_VecDeque.Test_CountOf_StartIndex_Func;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LCount: SizeUInt;
  LStartIndex: SizeUInt;
begin
  { 测试 CountOf_StartIndex_Func - 从指定索引开始使用函数指针统计元素 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 准备测试数据 }
    LVecDeque.PushBack(3);
    LVecDeque.PushBack(6);
    LVecDeque.PushBack(3);
    LVecDeque.PushBack(9);
    LVecDeque.PushBack(3);
    LVecDeque.PushBack(6);

    LStartIndex := 2;

    { 从索引2开始使用自定义比较函数统计元素3 }
    LCount := LVecDeque.CountOf(3, LStartIndex, @EqualsTestFunc, @Self);
    AssertEquals('应该从起始索引正确统计元素数量', SizeUInt(2), LCount);

    { 从索引0开始统计（应该统计全部） }
    LCount := LVecDeque.CountOf(3, 0, @EqualsTestFunc, @Self);
    AssertEquals('从索引0开始应该统计所有匹配元素', SizeUInt(3), LCount);

    { 从最后一个索引开始统计 }
    LCount := LVecDeque.CountOf(6, 5, @EqualsTestFunc, @Self);
    AssertEquals('从最后索引开始应该只统计最后的元素', SizeUInt(1), LCount);
  finally
    LVecDeque.Free;
  end;
end;

procedure TTestCase_VecDeque.Test_CountOf_StartIndex_Method;
var
  LVecDeque: specialize TVecDeque<Integer>;
  LCount: SizeUInt;
  LStartIndex: SizeUInt;
begin
  { 测试 CountOf_StartIndex_Method - 从指定索引开始使用方法指针统计元素 }
  LVecDeque := specialize TVecDeque<Integer>.Create;
  try
    { 准备测试数据 }
    LVecDeque.PushBack(5);
    LVecDeque.PushBack(10);
    LVecDeque.PushBack(5);
    LVecDeque.PushBack(15);
    LVecDeque.PushBack(5);
    LVecDeque.PushBack(10);
    LVecDeque.PushBack(5);

    LStartIndex := 3;

    { 从索引3开始使用方法指针统计元素5 }
    LCount := LVecDeque.CountOf(5, LStartIndex, @EqualsTestMethod, @Self);
    AssertEquals('应该从起始索引正确统计元素数量', SizeUInt(2), LCount);

