          <Version Value="11"/>
          <PathDelim Value="\"/>
          <Target>
            <Filename Value="..\..\bin\benchmark_micro_padon"/>
          </Target>
          <SearchPaths>
            <IncludeFiles Value="$(ProjOutDir);..\..\src"/>
